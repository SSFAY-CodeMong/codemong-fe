{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getMailDashboard, sendTestMail, updateMailSubscription } from '../api/codemong';\nexport default {\n  name: 'MailServicePage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      loading: false,\n      sending: false,\n      hasError: false,\n      message: '',\n      subscription: {\n        enabled: false,\n        email: ''\n      },\n      enabledDraft: false,\n      previewQuestion: null,\n      recentLogs: []\n    };\n  },\n  created() {\n    this.loadDashboard();\n  },\n  methods: {\n    async loadDashboard() {\n      this.loading = true;\n      this.message = '';\n      this.hasError = false;\n      try {\n        const dashboard = await getMailDashboard();\n        this.subscription = dashboard.subscription || {\n          enabled: false,\n          email: ''\n        };\n        this.enabledDraft = this.subscription.enabled;\n        this.previewQuestion = dashboard.previewQuestion;\n        this.recentLogs = dashboard.recentLogs || [];\n      } catch (error) {\n        this.hasError = true;\n        this.message = error.message;\n      } finally {\n        this.loading = false;\n      }\n    },\n    async saveSubscription() {\n      try {\n        this.subscription = await updateMailSubscription(this.enabledDraft);\n        this.enabledDraft = this.subscription.enabled;\n        this.hasError = false;\n        this.message = this.subscription.enabled ? '메일 구독이 켜졌습니다.' : '메일 구독이 꺼졌습니다.';\n      } catch (error) {\n        this.hasError = true;\n        this.message = error.message;\n        this.enabledDraft = this.subscription.enabled;\n      }\n    },\n    async sendTest() {\n      this.sending = true;\n      this.message = '';\n      try {\n        const log = await sendTestMail();\n        this.hasError = !log.success;\n        this.message = log.message;\n        await this.loadDashboard();\n      } catch (error) {\n        this.hasError = true;\n        this.message = error.message;\n      } finally {\n        this.sending = false;\n      }\n    },\n    formatDate(value) {\n      if (!value) return '';\n      return new Date(value).toLocaleString();\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getMailDashboard","sendTestMail","updateMailSubscription","name","components","data","loading","sending","hasError","message","subscription","enabled","email","enabledDraft","previewQuestion","recentLogs","created","loadDashboard","methods","dashboard","error","saveSubscription","sendTest","log","success","formatDate","value","Date","toLocaleString"],"sources":["src/views/mail-service-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mail\" />\n    <main class=\"page mail-page\">\n      <section class=\"mail-hero\">\n        <div>\n          <span class=\"badge\">DevDaily for Codemong</span>\n          <h1>메일서비스</h1>\n          <p>Codemong 계정 이메일로 개발 질문을 주기적으로 받아볼 수 있습니다. 현재 테스트 설정은 10분마다 랜덤 질문을 발송합니다.</p>\n        </div>\n        <div class=\"mail-status\" :class=\"{ active: subscription.enabled }\">\n          <strong>{{ subscription.enabled ? '구독 중' : '구독 꺼짐' }}</strong>\n          <span>{{ subscription.email || '이메일 없음' }}</span>\n        </div>\n      </section>\n\n      <section class=\"mail-layout\">\n        <article class=\"panel mail-control\">\n          <div class=\"section-head\">\n            <div>\n              <h2>발송 설정</h2>\n              <p>Spring Batch가 10분마다 활성 구독자에게 랜덤 질문을 발송합니다.</p>\n            </div>\n          </div>\n          <label class=\"toggle-row\">\n            <input type=\"checkbox\" v-model=\"enabledDraft\" @change=\"saveSubscription\" />\n            <span>메일 발송 받기</span>\n          </label>\n          <div class=\"toolbar\">\n            <button class=\"primary\" type=\"button\" @click=\"sendTest\" :disabled=\"sending\">\n              {{ sending ? '테스트 발송 중' : '테스트 메일 보내기' }}\n            </button>\n            <button class=\"secondary\" type=\"button\" @click=\"loadDashboard\" :disabled=\"loading\">새로고침</button>\n          </div>\n          <p v-if=\"message\" class=\"status\" :class=\"{ fail: hasError, ok: !hasError }\">{{ message }}</p>\n        </article>\n\n        <article class=\"panel\">\n          <h2>오늘의 랜덤 질문 미리보기</h2>\n          <div v-if=\"previewQuestion\" class=\"mail-question-card\">\n            <span class=\"badge\">{{ previewQuestion.category }} · {{ previewQuestion.difficulty }}</span>\n            <h3>{{ previewQuestion.title }}</h3>\n            <p>{{ previewQuestion.content }}</p>\n          </div>\n          <p v-else>아직 등록된 메일 질문이 없습니다.</p>\n        </article>\n      </section>\n\n      <section class=\"panel\">\n        <div class=\"section-head\">\n          <div>\n            <h2>최근 발송 로그</h2>\n            <p>SMTP 설정이 없으면 실제 발송은 스킵되고 로그만 남습니다.</p>\n          </div>\n        </div>\n        <ul v-if=\"recentLogs.length\" class=\"mail-log-list\">\n          <li v-for=\"log in recentLogs\" :key=\"log.id\" class=\"mail-log-item\" :class=\"{ success: log.success }\">\n            <div>\n              <strong>{{ log.questionTitle || log.mailType }}</strong>\n              <p>{{ log.message }}</p>\n            </div>\n            <span>{{ formatDate(log.createdAt) }}</span>\n          </li>\n        </ul>\n        <div v-else class=\"empty-state\">\n          <h2>발송 로그가 없습니다</h2>\n          <p>테스트 메일을 보내거나 Batch가 실행되면 여기에 결과가 표시됩니다.</p>\n        </div>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getMailDashboard, sendTestMail, updateMailSubscription } from '../api/codemong'\n\nexport default {\n  name: 'MailServicePage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      loading: false,\n      sending: false,\n      hasError: false,\n      message: '',\n      subscription: { enabled: false, email: '' },\n      enabledDraft: false,\n      previewQuestion: null,\n      recentLogs: [],\n    }\n  },\n  created() {\n    this.loadDashboard()\n  },\n  methods: {\n    async loadDashboard() {\n      this.loading = true\n      this.message = ''\n      this.hasError = false\n      try {\n        const dashboard = await getMailDashboard()\n        this.subscription = dashboard.subscription || { enabled: false, email: '' }\n        this.enabledDraft = this.subscription.enabled\n        this.previewQuestion = dashboard.previewQuestion\n        this.recentLogs = dashboard.recentLogs || []\n      } catch (error) {\n        this.hasError = true\n        this.message = error.message\n      } finally {\n        this.loading = false\n      }\n    },\n    async saveSubscription() {\n      try {\n        this.subscription = await updateMailSubscription(this.enabledDraft)\n        this.enabledDraft = this.subscription.enabled\n        this.hasError = false\n        this.message = this.subscription.enabled ? '메일 구독이 켜졌습니다.' : '메일 구독이 꺼졌습니다.'\n      } catch (error) {\n        this.hasError = true\n        this.message = error.message\n        this.enabledDraft = this.subscription.enabled\n      }\n    },\n    async sendTest() {\n      this.sending = true\n      this.message = ''\n      try {\n        const log = await sendTestMail()\n        this.hasError = !log.success\n        this.message = log.message\n        await this.loadDashboard()\n      } catch (error) {\n        this.hasError = true\n        this.message = error.message\n      } finally {\n        this.sending = false\n      }\n    },\n    formatDate(value) {\n      if (!value) return ''\n      return new Date(value).toLocaleString()\n    },\n  },\n}\n</script>\n"],"mappings":"AA2EA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,gBAAA,EAAAC,YAAA,EAAAC,sBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAN,SAAA;IAAAC;EAAA;EACAM,KAAA;IACA;MACAC,OAAA;MACA