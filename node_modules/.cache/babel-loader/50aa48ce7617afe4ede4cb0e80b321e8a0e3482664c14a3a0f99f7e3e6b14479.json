{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getLearningRepositories, getRepositoryStatus, saveRepository, stepNumber } from '../api/codemong';\nexport default {\n  name: 'MissionProgressPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      repositories: [],\n      selected: null,\n      status: {}\n    };\n  },\n  async created() {\n    await this.load();\n  },\n  methods: {\n    async load() {\n      const repos = await getLearningRepositories();\n      this.repositories = await Promise.all(repos.map(async repo => {\n        const status = await getRepositoryStatus(repo.repositoryId);\n        return {\n          ...repo,\n          status\n        };\n      }));\n      if (this.repositories[0]) await this.open(this.repositories[0]);\n    },\n    async open(repo) {\n      this.selected = repo;\n      saveRepository(repo);\n      this.status = repo.status || (await getRepositoryStatus(repo.repositoryId));\n      this.selected = {\n        ...repo,\n        status: this.status\n      };\n    },\n    currentStep(repo) {\n      return stepNumber(repo.status && repo.status.currentStep);\n    },\n    maxStep(repo) {\n      return repo.maxStep || repo.steps || repo.status && repo.status.maxStep || 5;\n    },\n    percent(repo) {\n      const max = this.maxStep(repo);\n      const current = Math.min(this.currentStep(repo), max);\n      const passedBonus = repo.status && repo.status.currentStepPassed ? 1 : 0;\n      return Math.min(100, Math.round((current - 1 + passedBonus) / max * 100));\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getLearningRepositories","getRepositoryStatus","saveRepository","stepNumber","name","components","data","repositories","selected","status","created","load","methods","repos","Promise","all","map","repo","repositoryId","open","currentStep","maxStep","steps","percent","max","current","Math","min","passedBonus","currentStepPassed","round"],"sources":["src/views/mission-progress-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"progress\" />\n    <main class=\"page progress-page fx-grid-bg\">\n      <section>\n        <div class=\"section-head\">\n          <div>\n            <span class=\"badge\">Progress</span>\n            <h1>진행 현황</h1>\n          </div>\n          <button class=\"secondary small nowrap\" type=\"button\" @click=\"load\">새로고침</button>\n        </div>\n\n        <div class=\"progress-grid\">\n          <article\n            v-for=\"repo in repositories\"\n            :key=\"repo.repositoryId\"\n            class=\"progress-card fx-card fx-hover\"\n            :class=\"{ selected: selected && selected.repositoryId === repo.repositoryId }\"\n            @click=\"open(repo)\"\n          >\n            <div class=\"progress-card__top\">\n              <span class=\"badge\">{{ repo.projectType }}</span>\n              <strong>{{ percent(repo) }}%</strong>\n            </div>\n            <h2>{{ repo.projectName }}</h2>\n            <p>{{ repo.name }}</p>\n            <div class=\"progress-track\">\n              <div class=\"progress-fill\" :style=\"{ width: `${percent(repo)}%` }\"></div>\n            </div>\n            <div class=\"progress-meta\">\n              <span>step {{ currentStep(repo) }} / {{ maxStep(repo) }}</span>\n              <span>{{ repo.status && repo.status.currentStepPassed ? '통과' : '진행 중' }}</span>\n            </div>\n          </article>\n        </div>\n      </section>\n\n      <aside class=\"panel fx-card progress-detail\">\n        <h2>현재 상태</h2>\n        <template v-if=\"status.repositoryId\">\n          <div class=\"big-percent\">{{ selected ? percent(selected) : 0 }}%</div>\n          <div class=\"progress-track large\">\n            <div class=\"progress-fill\" :style=\"{ width: `${selected ? percent(selected) : 0}%` }\"></div>\n          </div>\n          <p>현재 스텝: {{ status.currentStep }}</p>\n          <p>브랜치: {{ status.branchName }}</p>\n          <p>\n            완료 여부:\n            <span class=\"status\" :class=\"{ ok: status.completed }\">{{ status.completed ? '완료' : '진행 중' }}</span>\n          </p>\n          <button class=\"primary\" type=\"button\" @click=\"$router.push('/mission-workspace')\">미션으로 이동</button>\n        </template>\n        <p v-else>진행 중인 프로젝트를 선택하세요.</p>\n      </aside>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getLearningRepositories, getRepositoryStatus, saveRepository, stepNumber } from '../api/codemong'\n\nexport default {\n  name: 'MissionProgressPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      repositories: [],\n      selected: null,\n      status: {},\n    }\n  },\n  async created() {\n    await this.load()\n  },\n  methods: {\n    async load() {\n      const repos = await getLearningRepositories()\n      this.repositories = await Promise.all(repos.map(async repo => {\n        const status = await getRepositoryStatus(repo.repositoryId)\n        return { ...repo, status }\n      }))\n      if (this.repositories[0]) await this.open(this.repositories[0])\n    },\n    async open(repo) {\n      this.selected = repo\n      saveRepository(repo)\n      this.status = repo.status || await getRepositoryStatus(repo.repositoryId)\n      this.selected = { ...repo, status: this.status }\n    },\n    currentStep(repo) {\n      return stepNumber(repo.status && repo.status.currentStep)\n    },\n    maxStep(repo) {\n      return repo.maxStep || repo.steps || repo.status && repo.status.maxStep || 5\n    },\n    percent(repo) {\n      const max = this.maxStep(repo)\n      const current = Math.min(this.currentStep(repo), max)\n      const passedBonus = repo.status && repo.status.currentStepPassed ? 1 : 0\n      return Math.min(100, Math.round(((current - 1 + passedBonus) / max) * 100))\n    },\n  },\n}\n</script>\n"],"mappings":";;AA6DA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,uBAAA,EAAAC,mBAAA,EAAAC,cAAA,EAAAC,UAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAP,SAAA;IAAAC;EAAA;EACAO,KAAA;IACA;MACAC,YAAA;MACAC,QAAA;MACAC,MAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA,WAAAC,IAAA;EACA;EACAC,OAAA;IACA,MAAAD,KAAA;MACA,MAAAE,KAAA,SAAAb,uBAAA;MACA,KAAAO,YAAA,SAAAO,OAAA,CAAAC,GAAA,CAAAF,KAAA,CAAAG,GAAA,OAAAC,IAAA;QACA,MAAAR,MAAA,SAAAR,mBAAA,CAAAgB,IAAA,CAAAC,YAAA;QACA;UAAA,GAAAD,IAAA;UAAAR;QAAA;MACA;MACA,SAAAF,YAAA,gBAAAY,IAAA,MAAAZ,YAAA;IACA;IACA,MAAAY,KAAAF,IAAA;MACA,KAAAT,QAAA,GAAAS,IAAA;MACAf,cAAA,CAAAe,IAAA;MACA,KAAAR,MAAA,GAAAQ,IAAA,CAAAR,MAAA,WAAAR,mBAAA,CAAAgB,IAAA,CAAAC,YAAA;MACA,KAAAV,QAAA;QAAA,GAAAS,IAAA;QAAAR,MAAA,OAAAA;MAAA;IACA;IACAW,YAAAH,IAAA;MACA,OAAAd,UAAA,CAAAc,IAAA,CAAAR,MAAA,IAAAQ,IAAA,CAAAR,MAAA,CAAAW,WAAA;IACA;IACAC,QAAAJ,IAAA;MACA,OAAAA,IAAA,CAAAI,OAAA,IAAAJ,IAAA,CAAAK,KAAA,IAAAL,IAAA,CAAAR,MAAA,IAAAQ,IAAA,CAAAR,MAAA,CAAAY,OAAA;IACA;IACAE,QAAAN,IAAA;MACA,MAAAO,GAAA,QAAAH,OAAA,CAAAJ,IAAA;MACA,MAAAQ,OAAA,GAAAC,IAAA,CAAAC,GAAA,MAAAP,WAAA,CAAAH,IAAA,GAAAO,GAAA;MACA,MAAAI,WAAA,GAAAX,IAAA,CAAAR,MAAA,IAAAQ,IAAA,CAAAR,MAAA,CAAAoB,iBAAA;MACA,OAAAH,IAAA,CAAAC,GAAA,MAAAD,IAAA,CAAAI,KAAA,EAAAL,OAAA,OAAAG,WAAA,IAAAJ,GAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}