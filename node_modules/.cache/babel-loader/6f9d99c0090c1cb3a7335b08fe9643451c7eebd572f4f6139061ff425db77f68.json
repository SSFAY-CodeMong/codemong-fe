{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getRepositoryCompleted, getSavedRepository } from '../api/codemong';\nexport default {\n  name: 'CompletionPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      completed: false\n    };\n  },\n  async created() {\n    const repository = getSavedRepository();\n    if (repository) {\n      const result = await getRepositoryCompleted(repository.repositoryId);\n      this.completed = result.completed;\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getRepositoryCompleted","getSavedRepository","name","components","data","completed","created","repository","result","repositoryId"],"sources":["src/views/completion-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"progress\" />\n    <main class=\"page\">\n      <section class=\"panel\">\n        <h1>프로젝트 완료</h1>\n        <p>{{ completed ? '모든 스텝을 완료했습니다.' : '아직 완료되지 않았습니다. 진행 현황을 확인하세요.' }}</p>\n        <div class=\"toolbar\">\n          <button class=\"primary\" type=\"button\" @click=\"$router.push('/mission-progress')\">진행 현황</button>\n          <button class=\"secondary\" type=\"button\" @click=\"$router.push('/projects')\">다른 프로젝트</button>\n        </div>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getRepositoryCompleted, getSavedRepository } from '../api/codemong'\n\nexport default {\n  name: 'CompletionPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return { completed: false }\n  },\n  async created() {\n    const repository = getSavedRepository()\n    if (repository) {\n      const result = await getRepositoryCompleted(repository.repositoryId)\n      this.completed = result.completed\n    }\n  },\n}\n</script>\n"],"mappings":"AAkBA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,sBAAA,EAAAC,kBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAL,SAAA;IAAAC;EAAA;EACAK,KAAA;IACA;MAAAC,SAAA;IAAA;EACA;EACA,MAAAC,QAAA;IACA,MAAAC,UAAA,GAAAN,kBAAA;IACA,IAAAM,UAAA;MACA,MAAAC,MAAA,SAAAR,sBAAA,CAAAO,UAAA,CAAAE,YAAA;MACA,KAAAJ,SAAA,GAAAG,MAAA,CAAAH,SAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}