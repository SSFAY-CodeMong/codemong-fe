{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { askCodeQuestion, getSavedCheckResult, getSavedRepository } from '../api/codemong';\nexport default {\n  name: 'MissionResultPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  props: {\n    forcedStatus: {\n      type: String,\n      default: ''\n    }\n  },\n  data() {\n    const result = getSavedCheckResult() || {};\n    return {\n      result,\n      question: '',\n      answer: '',\n      asking: false\n    };\n  },\n  computed: {\n    status() {\n      return this.result.status || this.forcedStatus || 'UNKNOWN';\n    },\n    passed() {\n      return this.status === 'PASSED' || this.forcedStatus === 'PASSED';\n    },\n    failedTests() {\n      return this.result.failedTests || [];\n    },\n    failureMessage() {\n      return this.result.message || '실패한 테스트 또는 GitHub Actions 오류를 확인하세요.';\n    }\n  },\n  methods: {\n    async ask() {\n      const repository = getSavedRepository();\n      if (!repository) {\n        this.answer = '선택된 저장소가 없습니다.';\n        return;\n      }\n      this.asking = true;\n      try {\n        const context = `${this.question}\\n\\n검사 상태: ${this.status}\\n실패 원인: ${this.failureMessage}`;\n        const result = await askCodeQuestion(repository.repositoryId, context);\n        this.answer = result.answer || result.response || JSON.stringify(result);\n      } catch (error) {\n        this.answer = error.message;\n      } finally {\n        this.asking = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","askCodeQuestion","getSavedCheckResult","getSavedRepository","name","components","props","forcedStatus","type","String","default","data","result","question","answer","asking","computed","status","passed","failedTests","failureMessage","message","methods","ask","repository","context","repositoryId","response","JSON","stringify","error"],"sources":["src/views/mission-result-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mission\" />\n    <main class=\"page result-page\">\n      <section class=\"result-summary\" :class=\"{ pass: passed, fail: !passed }\">\n        <span class=\"badge\">{{ status }}</span>\n        <h1>{{ passed ? '요구사항을 통과했습니다' : '오류 원인을 확인하세요' }}</h1>\n        <p>{{ passed ? '현재 스텝이 통과 상태로 저장되었습니다. 다음 스텝으로 이동할 수 있습니다.' : failureMessage }}</p>\n        <div class=\"toolbar\">\n          <button v-if=\"passed\" class=\"primary\" type=\"button\" @click=\"$router.push('/next-step-loading')\">다음 스텝 이동</button>\n          <button class=\"secondary\" type=\"button\" @click=\"$router.push('/mission-workspace')\">미션으로 돌아가기</button>\n        </div>\n      </section>\n\n      <section class=\"result-grid\">\n        <article class=\"panel\">\n          <h2>{{ passed ? '통과 요약' : '오류 원인' }}</h2>\n          <ul class=\"check-list\" v-if=\"failedTests.length\">\n            <li v-for=\"test in failedTests\" :key=\"test\">{{ test }}</li>\n          </ul>\n          <p v-else>{{ passed ? 'Hidden test가 성공으로 종료되었습니다.' : failureMessage }}</p>\n        </article>\n\n        <article class=\"panel\">\n          <h2>코드 질문</h2>\n          <p>현재 결과를 바탕으로 수정 방향을 질문할 수 있습니다. LLM API가 준비되지 않았으면 기본 응답만 표시됩니다.</p>\n          <form class=\"form\" @submit.prevent=\"ask\">\n            <textarea v-model=\"question\" rows=\"5\" placeholder=\"왜 실패했는지, 어떤 파일부터 보면 좋을지 질문하세요.\"></textarea>\n            <button class=\"primary\" type=\"submit\" :disabled=\"asking\">질문 보내기</button>\n          </form>\n          <div class=\"answer-box\">{{ answer || '응답이 여기에 표시됩니다.' }}</div>\n        </article>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { askCodeQuestion, getSavedCheckResult, getSavedRepository } from '../api/codemong'\n\nexport default {\n  name: 'MissionResultPage',\n  components: { AppFooter, AppHeader },\n  props: {\n    forcedStatus: {\n      type: String,\n      default: '',\n    },\n  },\n  data() {\n    const result = getSavedCheckResult() || {}\n    return {\n      result,\n      question: '',\n      answer: '',\n      asking: false,\n    }\n  },\n  computed: {\n    status() {\n      return this.result.status || this.forcedStatus || 'UNKNOWN'\n    },\n    passed() {\n      return this.status === 'PASSED' || this.forcedStatus === 'PASSED'\n    },\n    failedTests() {\n      return this.result.failedTests || []\n    },\n    failureMessage() {\n      return this.result.message || '실패한 테스트 또는 GitHub Actions 오류를 확인하세요.'\n    },\n  },\n  methods: {\n    async ask() {\n      const repository = getSavedRepository()\n      if (!repository) {\n        this.answer = '선택된 저장소가 없습니다.'\n        return\n      }\n      this.asking = true\n      try {\n        const context = `${this.question}\\n\\n검사 상태: ${this.status}\\n실패 원인: ${this.failureMessage}`\n        const result = await askCodeQuestion(repository.repositoryId, context)\n        this.answer = result.answer || result.response || JSON.stringify(result)\n      } catch (error) {\n        this.answer = error.message\n      } finally {\n        this.asking = false\n      }\n    },\n  },\n}\n</script>\n"],"mappings":"AAuCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,eAAA,EAAAC,mBAAA,EAAAC,kBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAN,SAAA;IAAAC;EAAA;EACAM,KAAA;IACAC,YAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;EACA;EACAC,KAAA;IACA,MAAAC,MAAA,GAAAV,mBAAA;IACA;MACAU,MAAA;MACAC,QAAA;MACAC,MAAA;MACAC,MAAA;IACA;EACA;EACAC,QAAA;IACAC,OAAA;MACA,YAAAL,MAAA,CAAAK,MAAA,SAAAV,YAAA;IACA;IACAW,OAAA;MACA,YAAAD,MAAA,sBAAAV,YAAA;IACA;IACAY,YAAA;MACA,YAAAP,MAAA,CAAAO,WAAA;IACA;IACAC,eAAA;MACA,YAAAR,MAAA,CAAAS,OAAA;IACA;EACA;EACAC,OAAA;IACA,MAAAC,IAAA;MACA,MAAAC,UAAA,GAAArB,kBAAA;MACA,KAAAqB,UAAA;QACA,KAAAV,MAAA;QACA;MACA;MACA,KAAAC,MAAA;MACA;QACA,MAAAU,OAAA,WAAAZ,QAAA,mBAAAI,MAAA,iBAAAG,cAAA;QACA,MAAAR,MAAA,SAAAX,eAAA,CAAAuB,UAAA,CAAAE,YAAA,EAAAD,OAAA;QACA,KAAAX,MAAA,GAAAF,MAAA,CAAAE,MAAA,IAAAF,MAAA,CAAAe,QAAA,IAAAC,IAAA,CAAAC,SAAA,CAAAjB,MAAA;MACA,SAAAkB,KAAA;QACA,KAAAhB,MAAA,GAAAgB,KAAA,CAAAT,OAAA;MACA;QACA,KAAAN,MAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}