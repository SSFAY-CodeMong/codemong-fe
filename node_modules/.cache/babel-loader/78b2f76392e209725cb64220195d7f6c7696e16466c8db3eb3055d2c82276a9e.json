{"ast":null,"code":"import \"core-js/modules/es.array.includes.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getProjectStartRequest, getSavedRepository, startProject } from '../api/codemong';\nexport default {\n  name: 'ProjectInitializingPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      repository: getSavedRepository(),\n      title: '학습 저장소를 준비하고 있습니다',\n      message: 'GitHub 저장소 생성과 starter 코드 복사는 잠시 걸릴 수 있습니다.',\n      phase: 1,\n      done: false,\n      failed: false,\n      needsLogin: false,\n      timer: null\n    };\n  },\n  async created() {\n    this.timer = window.setInterval(() => {\n      if (!this.done && !this.failed) this.phase = Math.min(3, this.phase + 1);\n    }, 1800);\n    const request = getProjectStartRequest();\n    if (!request) {\n      if (this.repository) {\n        this.done = true;\n        this.phase = 3;\n        this.title = '저장소 준비 완료';\n        this.message = '이미 생성된 학습 저장소가 있습니다.';\n        return;\n      }\n      this.$router.replace('/projects');\n      return;\n    }\n    try {\n      this.repository = await startProject(request.project.id, request.payload);\n      this.phase = 3;\n      this.done = true;\n      this.title = '저장소 준비 완료';\n      this.message = 'GitHub 저장소와 첫 작업 브랜치가 생성되었습니다.';\n    } catch (error) {\n      this.failed = true;\n      this.needsLogin = error.message.includes('로그인');\n      this.title = '저장소 생성 실패';\n      this.message = error.message;\n    }\n  },\n  beforeDestroy() {\n    window.clearInterval(this.timer);\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getProjectStartRequest","getSavedRepository","startProject","name","components","data","repository","title","message","phase","done","failed","needsLogin","timer","created","window","setInterval","Math","min","request","$router","replace","project","id","payload","error","includes","beforeDestroy","clearInterval"],"sources":["src/views/project-initializing-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mission\" />\n    <main class=\"page loading-page\">\n      <section class=\"loading-panel\">\n        <div class=\"loader-orbit\" aria-hidden=\"true\">\n          <span></span>\n          <span></span>\n          <span></span>\n        </div>\n        <div>\n          <span class=\"badge\">{{ done ? 'READY' : 'CREATING' }}</span>\n          <h1>{{ title }}</h1>\n          <p>{{ message }}</p>\n        </div>\n        <ol class=\"loading-steps\">\n          <li :class=\"{ active: phase >= 1, done: phase > 1 }\">GitHub 저장소 생성</li>\n          <li :class=\"{ active: phase >= 2, done: phase > 2 }\">브랜치 준비</li>\n          <li :class=\"{ active: phase >= 3, done }\">starter 코드 복사</li>\n        </ol>\n        <div class=\"toolbar\">\n          <button v-if=\"done\" class=\"primary\" type=\"button\" @click=\"$router.push('/mission-workspace')\">미션으로 이동</button>\n          <a v-if=\"repository\" class=\"secondary\" :href=\"repository.htmlUrl\" target=\"_blank\" rel=\"noreferrer\">GitHub 열기</a>\n          <button v-if=\"failed\" class=\"secondary\" type=\"button\" @click=\"$router.push('/project-setup')\">설정으로 돌아가기</button>\n          <button v-if=\"needsLogin\" class=\"primary\" type=\"button\" @click=\"$router.push('/login')\">GitHub 로그인</button>\n        </div>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getProjectStartRequest, getSavedRepository, startProject } from '../api/codemong'\n\nexport default {\n  name: 'ProjectInitializingPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      repository: getSavedRepository(),\n      title: '학습 저장소를 준비하고 있습니다',\n      message: 'GitHub 저장소 생성과 starter 코드 복사는 잠시 걸릴 수 있습니다.',\n      phase: 1,\n      done: false,\n      failed: false,\n      needsLogin: false,\n      timer: null,\n    }\n  },\n  async created() {\n    this.timer = window.setInterval(() => {\n      if (!this.done && !this.failed) this.phase = Math.min(3, this.phase + 1)\n    }, 1800)\n\n    const request = getProjectStartRequest()\n    if (!request) {\n      if (this.repository) {\n        this.done = true\n        this.phase = 3\n        this.title = '저장소 준비 완료'\n        this.message = '이미 생성된 학습 저장소가 있습니다.'\n        return\n      }\n      this.$router.replace('/projects')\n      return\n    }\n\n    try {\n      this.repository = await startProject(request.project.id, request.payload)\n      this.phase = 3\n      this.done = true\n      this.title = '저장소 준비 완료'\n      this.message = 'GitHub 저장소와 첫 작업 브랜치가 생성되었습니다.'\n    } catch (error) {\n      this.failed = true\n      this.needsLogin = error.message.includes('로그인')\n      this.title = '저장소 생성 실패'\n      this.message = error.message\n    }\n  },\n  beforeDestroy() {\n    window.clearInterval(this.timer)\n  },\n}\n</script>\n"],"mappings":";AAiCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,sBAAA,EAAAC,kBAAA,EAAAC,YAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAN,SAAA;IAAAC;EAAA;EACAM,KAAA;IACA;MACAC,UAAA,EAAAL,kBAAA;MACAM,KAAA;MACAC,OAAA;MACAC,KAAA;MACAC,IAAA;MACAC,MAAA;MACAC,UAAA;MACAC,KAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA,KAAAD,KAAA,GAAAE,MAAA,CAAAC,WAAA;MACA,UAAAN,IAAA,UAAAC,MAAA,OAAAF,KAAA,GAAAQ,IAAA,CAAAC,GAAA,SAAAT,KAAA;IACA;IAEA,MAAAU,OAAA,GAAAnB,sBAAA;IACA,KAAAmB,OAAA;MACA,SAAAb,UAAA;QACA,KAAAI,IAAA;QACA,KAAAD,KAAA;QACA,KAAAF,KAAA;QACA,KAAAC,OAAA;QACA;MACA;MACA,KAAAY,OAAA,CAAAC,OAAA;MACA;IACA;IAEA;MACA,KAAAf,UAAA,SAAAJ,YAAA,CAAAiB,OAAA,CAAAG,OAAA,CAAAC,EAAA,EAAAJ,OAAA,CAAAK,OAAA;MACA,KAAAf,KAAA;MACA,KAAAC,IAAA;MACA,KAAAH,KAAA;MACA,KAAAC,OAAA;IACA,SAAAiB,KAAA;MACA,KAAAd,MAAA;MACA,KAAAC,UAAA,GAAAa,KAAA,CAAAjB,OAAA,CAAAkB,QAAA;MACA,KAAAnB,KAAA;MACA,KAAAC,OAAA,GAAAiB,KAAA,CAAAjB,OAAA;IACA;EACA;EACAmB,cAAA;IACAZ,MAAA,CAAAa,aAAA,MAAAf,KAAA;EACA;AACA","ignoreList":[]},"me