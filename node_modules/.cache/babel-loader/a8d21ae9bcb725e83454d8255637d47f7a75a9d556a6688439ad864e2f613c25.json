{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getCodeCheckStatus, getSavedCheckId, saveCheckResult } from '../api/codemong';\nexport default {\n  name: 'InspectionRunningPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      checkId: getSavedCheckId(),\n      status: 'RUNNING',\n      failedTests: [],\n      reviewContent: '',\n      message: '',\n      timer: null\n    };\n  },\n  computed: {\n    shortCheckId() {\n      return this.checkId ? this.checkId.slice(0, 8) : '-';\n    },\n    passed() {\n      return this.status === 'PASSED';\n    },\n    failed() {\n      return this.status === 'FAILED' || this.status === 'ERROR';\n    },\n    title() {\n      if (this.passed) return '검사를 통과했습니다';\n      if (this.failed) return '검사에서 확인할 문제가 있습니다';\n      return 'GitHub Actions가 코드를 검사 중입니다';\n    },\n    description() {\n      if (this.passed) return '요구사항을 만족했습니다. 결과 화면에서 다음 스텝으로 이동할 수 있습니다.';\n      if (this.failed) return '실패 원인과 테스트 메시지를 확인하고 코드 수정 방향을 정리하세요.';\n      return '원격 브랜치의 최신 커밋을 기준으로 hidden test를 실행하고 있습니다.';\n    }\n  },\n  created() {\n    if (!this.checkId) {\n      this.$router.replace('/mission-workspace');\n      return;\n    }\n    this.poll();\n    this.timer = window.setInterval(this.poll, 3000);\n  },\n  beforeDestroy() {\n    window.clearInterval(this.timer);\n  },\n  methods: {\n    async poll() {\n      try {\n        const result = await getCodeCheckStatus(this.checkId);\n        this.status = result.status;\n        this.failedTests = result.failedTests || [];\n        this.reviewContent = result.reviewContent || '';\n        this.message = result.message || '';\n        saveCheckResult(result);\n        if (this.passed || this.failed) window.clearInterval(this.timer);\n      } catch (error) {\n        this.status = 'ERROR';\n        this.message = error.message;\n        saveCheckResult({\n          checkId: this.checkId,\n          status: 'ERROR',\n          message: error.message,\n          failedTests: []\n        });\n        window.clearInterval(this.timer);\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getCodeCheckStatus","getSavedCheckId","saveCheckResult","name","components","data","checkId","status","failedTests","reviewContent","message","timer","computed","shortCheckId","slice","passed","failed","title","description","created","$router","replace","poll","window","setInterval","beforeDestroy","clearInterval","methods","result","error"],"sources":["src/views/inspection-running-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mission\" />\n    <main class=\"page inspection-page\">\n      <section class=\"inspection-panel\">\n        <div class=\"scan-visual\" :class=\"{ done: passed, failed }\">\n          <div class=\"scan-ring\"></div>\n          <div class=\"scan-core\">{{ status }}</div>\n        </div>\n        <div>\n          <span class=\"badge\">checkId {{ shortCheckId }}</span>\n          <h1>{{ title }}</h1>\n          <p>{{ description }}</p>\n        </div>\n        <ol class=\"inspection-steps\">\n          <li :class=\"{ active: true, done: status !== 'RUNNING' }\">검사 요청 등록</li>\n          <li :class=\"{ active: status === 'RUNNING', done: passed || failed }\">GitHub Actions 실행 대기</li>\n          <li :class=\"{ active: passed || failed, done: passed }\">테스트 결과 수집</li>\n        </ol>\n        <p v-if=\"message\" class=\"status fail\">{{ message }}</p>\n        <div class=\"toolbar\">\n          <button class=\"secondary\" type=\"button\" @click=\"poll\">새로고침</button>\n          <button v-if=\"passed\" class=\"primary\" type=\"button\" @click=\"$router.push('/mission-passed')\">통과 결과 보기</button>\n          <button v-if=\"failed\" class=\"danger\" type=\"button\" @click=\"$router.push('/mission-failed')\">실패 결과 보기</button>\n        </div>\n      </section>\n      <section v-if=\"reviewContent\" class=\"panel inspection-feedback\">\n        <div class=\"section-head\">\n          <div>\n            <span class=\"badge\">AI Feedback</span>\n            <h2>제출 코드 전체 피드백</h2>\n          </div>\n        </div>\n        <div class=\"answer-box\">{{ reviewContent }}</div>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getCodeCheckStatus, getSavedCheckId, saveCheckResult } from '../api/codemong'\n\nexport default {\n  name: 'InspectionRunningPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      checkId: getSavedCheckId(),\n      status: 'RUNNING',\n      failedTests: [],\n      reviewContent: '',\n      message: '',\n      timer: null,\n    }\n  },\n  computed: {\n    shortCheckId() {\n      return this.checkId ? this.checkId.slice(0, 8) : '-'\n    },\n    passed() {\n      return this.status === 'PASSED'\n    },\n    failed() {\n      return this.status === 'FAILED' || this.status === 'ERROR'\n    },\n    title() {\n      if (this.passed) return '검사를 통과했습니다'\n      if (this.failed) return '검사에서 확인할 문제가 있습니다'\n      return 'GitHub Actions가 코드를 검사 중입니다'\n    },\n    description() {\n      if (this.passed) return '요구사항을 만족했습니다. 결과 화면에서 다음 스텝으로 이동할 수 있습니다.'\n      if (this.failed) return '실패 원인과 테스트 메시지를 확인하고 코드 수정 방향을 정리하세요.'\n      return '원격 브랜치의 최신 커밋을 기준으로 hidden test를 실행하고 있습니다.'\n    },\n  },\n  created() {\n    if (!this.checkId) {\n      this.$router.replace('/mission-workspace')\n      return\n    }\n    this.poll()\n    this.timer = window.setInterval(this.poll, 3000)\n  },\n  beforeDestroy() {\n    window.clearInterval(this.timer)\n  },\n  methods: {\n    async poll() {\n      try {\n        const result = await getCodeCheckStatus(this.checkId)\n        this.status = result.status\n        this.failedTests = result.failedTests || []\n        this.reviewContent = result.reviewContent || ''\n        this.message = result.message || ''\n        saveCheckResult(result)\n        if (this.passed || this.failed) window.clearInterval(this.timer)\n      } catch (error) {\n        this.status = 'ERROR'\n        this.message = error.message\n        saveCheckResult({ checkId: this.checkId, status: 'ERROR', message: error.message, failedTests: [] })\n        window.clearInterval(this.timer)\n      }\n    },\n  },\n}\n</script>\n"],"mappings":"AAyCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,kBAAA,EAAAC,eAAA,EAAAC,eAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAN,SAAA;IAAAC;EAAA;EACAM,KAAA;IACA;MACAC,OAAA,EAAAL,eAAA;MACAM,MAAA;MACAC,WAAA;MACAC,aAAA;MACAC,OAAA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACAC,aAAA;MACA,YAAAP,OAAA,QAAAA,OAAA,CAAAQ,KAAA;IACA;IACAC,OAAA;MACA,YAAAR,MAAA;IACA;IACAS,OAAA;MACA,YAAAT,MAAA,sBAAAA,MAAA;IACA;IACAU,MAAA;MACA,SAAAF,MAAA;MACA,SAAAC,MAAA;MACA;IACA;IACAE,YAAA;MACA,SAAAH,MAAA;MACA,SAAAC,MAAA;MACA;IACA;EACA;EACAG,QAAA;IACA,UAAAb,OAAA;MACA,KAAAc,OAAA,CAAAC,OAAA;MACA;IACA;IACA,KAAAC,IAAA;IACA,KAAAX,KAAA,GAAAY,MAAA,CAAAC,WAAA,MAAAF,IAAA;EACA;EACAG,cAAA;IACAF,MAAA,CAAAG,aAAA,MAAAf,KAAA;EACA;EACAgB,OAAA;IACA,MAAAL,KAAA;MACA;QACA,MAAAM,MAAA,SAAA5B,kBAAA,MAAAM,OAAA;QACA,KAAAC,MAAA,GAAAqB,MAAA,CAAArB,MAAA;QACA,KAAAC,WAAA,GAAAoB,MAAA,CAAApB,WAAA;QACA,KAAAC,aAAA,GAAAmB,MAAA,CAAAnB,aAAA;QACA,KAAAC,OAAA,GAAAkB,MAAA,CAAAlB,OAAA;QACAR,eAAA,CAAA0B,MAAA;QACA,SAAAb,MAAA,SAAAC,MAAA,EAAAO,MAAA,CAAAG,aAAA,MAAAf,KAAA;MACA,SAAAkB,KAAA;QACA,KAAAtB,MAAA;QACA,KAAAG,OAAA,GAAAmB,KAAA,CAAAnB,OAAA;QACAR,eAAA;UAAAI,OAAA,OAAAA,OAAA;UAAAC,MAAA;UAAAG,OAAA,EAAAmB,KAAA,CAAAnB,OAAA;UAAAF,WAAA;QAAA;QACAe,MAAA,CAAAG,aAAA,MAAAf,KAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}