{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getLearningRepositories, getRepositoryStatus, saveRepository } from '../api/codemong';\nexport default {\n  name: 'MissionProgressPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      repositories: [],\n      status: {}\n    };\n  },\n  async created() {\n    this.repositories = await getLearningRepositories();\n    if (this.repositories[0]) await this.open(this.repositories[0]);\n  },\n  methods: {\n    async open(repo) {\n      saveRepository(repo);\n      this.status = await getRepositoryStatus(repo.repositoryId);\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getLearningRepositories","getRepositoryStatus","saveRepository","name","components","data","repositories","status","created","open","methods","repo","repositoryId"],"sources":["src/views/mission-progress-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"progress\" />\n    <main class=\"page layout\">\n      <section>\n        <h1>진행 현황</h1>\n        <div class=\"grid\">\n          <article v-for=\"repo in repositories\" :key=\"repo.repositoryId\" class=\"card\">\n            <span class=\"badge\">{{ repo.projectType }}</span>\n            <h2>{{ repo.projectName }}</h2>\n            <p>{{ repo.name }}</p>\n            <div class=\"toolbar\">\n              <button class=\"secondary small\" type=\"button\" @click=\"open(repo)\">선택</button>\n              <a :href=\"repo.htmlUrl\" target=\"_blank\" rel=\"noreferrer\">GitHub</a>\n            </div>\n          </article>\n        </div>\n      </section>\n      <aside class=\"panel\">\n        <h2>현재 상태</h2>\n        <p v-if=\"status.repositoryId\">현재 스텝: {{ status.currentStep }}</p>\n        <p v-if=\"status.repositoryId\">브랜치: {{ status.branchName }}</p>\n        <p v-if=\"status.repositoryId\">\n          완료 여부:\n          <span class=\"status\" :class=\"{ ok: status.completed }\">{{ status.completed ? '완료' : '진행 중' }}</span>\n        </p>\n        <button class=\"primary\" type=\"button\" @click=\"$router.push('/mission-workspace')\" :disabled=\"!status.repositoryId\">\n          미션으로 이동\n        </button>\n      </aside>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getLearningRepositories, getRepositoryStatus, saveRepository } from '../api/codemong'\n\nexport default {\n  name: 'MissionProgressPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      repositories: [],\n      status: {},\n    }\n  },\n  async created() {\n    this.repositories = await getLearningRepositories()\n    if (this.repositories[0]) await this.open(this.repositories[0])\n  },\n  methods: {\n    async open(repo) {\n      saveRepository(repo)\n      this.status = await getRepositoryStatus(repo.repositoryId)\n    },\n  },\n}\n</script>\n"],"mappings":"AAoCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,uBAAA,EAAAC,mBAAA,EAAAC,cAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAN,SAAA;IAAAC;EAAA;EACAM,KAAA;IACA;MACAC,YAAA;MACAC,MAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA,KAAAF,YAAA,SAAAN,uBAAA;IACA,SAAAM,YAAA,gBAAAG,IAAA,MAAAH,YAAA;EACA;EACAI,OAAA;IACA,MAAAD,KAAAE,IAAA;MACAT,cAAA,CAAAS,IAAA;MACA,KAAAJ,MAAA,SAAAN,mBAAA,CAAAU,IAAA,CAAAC,YAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}