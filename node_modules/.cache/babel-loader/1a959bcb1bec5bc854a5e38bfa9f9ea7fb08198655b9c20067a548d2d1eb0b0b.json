s.status.projectId, step)\n    },\n    async startCheck() {\n      this.checking = true\n      this.message = ''\n      try {\n        const step = stepNumber(this.status.currentStep)\n        await startCodeCheck(this.repository.repositoryId, step)\n        this.$router.push('/inspection-running')\n      } catch (error) {\n        this.message = error.message\n      } finally {\n        this.checking = false\n      }\n    },\n  },\n}\n</script>\n"],"mappings":";AAoCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,mBAAA,EAAAC,kBAAA,EAAAC,WAAA,EAAAC,cAAA,EAAAC,UAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAR,SAAA;IAAAC;EAAA;EACAQ,KAAA;IACA;MACAC,UAAA,EAAAP,kBAAA;MACAQ,MAAA;MACAC,IAAA;QAAAC,YAAA;MAAA;MACAC,QAAA;MACAC,OAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA,UAAAN,UAAA;MACA,KAAAO,OAAA,CAAAC,OAAA;MACA;IACA;IACA,WAAAC,IAAA;EACA;EACAC,OAAA;IACA,MAAAD,KAAA;MACA,KAAAR,MAAA,SAAAT,mBAAA,MAAAQ,UAAA,CAAAW,YAAA;MACA,MAAAC,IAAA,GAAAhB,UAAA,MAAAK,MAAA,CAAAY,WAAA;MACA,KAAAX,IAAA,SAAAR,WAAA,MAAAO,MAAA,CAAAa,SAAA,EAAAF,IAAA;IACA;IACA,MAAAG,WAAA;MACA,KAAAX,QAAA;MACA,KAAAC,OAAA;MACA;QACA,MAAAO,IAAA,GAAAhB,UAAA,MAAAK,MAAA,CAAAY,WAAA;QACA,MAAAlB,cAAA,MAAAK,UAAA,CAAAW,YAAA,EAAAC,IAAA;QACA,KAAAL,OAAA,CAAAS,IAAA;MACA,SAAAC,KAAA;QACA,KAAAZ,OAAA,GAAAY,KAAA,CAAAZ,OAAA;MACA;QACA,KAAAD,QAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}