{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getNavigation } from '../api/codemong';\nexport default {\n  name: 'HelpPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      navigation: []\n    };\n  },\n  async created() {\n    this.navigation = await getNavigation();\n  },\n  metaInfo: {\n    title: '도움말',\n    meta: [{\n      property: 'og:title',\n      content: '도움말'\n    }]\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getNavigation","name","components","data","navigation","created","metaInfo","title","meta","property","content"],"sources":["src/views/help-page.vue"],"sourcesContent":["<template>\n  <main class=\"help-page\">\n    <AppHeader active-page=\"help\" :navigation=\"navigation\" />\n\n    <section class=\"help-page__hero\">\n      <p class=\"help-page__eyebrow\">지원 센터</p>\n      <h1>프로젝트 진행 중 막히는 지점을 빠르게 확인하세요</h1>\n      <p>\n        Codemong의 프로젝트 선택, 미션 진행, 검사 결과, AI 피드백 흐름을 한곳에서 정리했습니다.\n      </p>\n    </section>\n\n    <section class=\"help-page__grid\">\n      <article class=\"help-page__card\">\n        <span>01</span>\n        <h2>프로젝트 시작</h2>\n        <p>프로젝트 목록에서 원하는 난이도와 기술 스택을 확인한 뒤 시작 스텝을 선택하세요.</p>\n        <button type=\"button\" @click=\"$router.push('/projects')\">프로젝트 보기</button>\n      </article>\n      <article class=\"help-page__card\">\n        <span>02</span>\n        <h2>미션 작성</h2>\n        <p>요구사항과 예시 코드를 확인하고 GitHub에 코드를 푸시하면 검사 흐름으로 이동할 수 있습니다.</p>\n        <button type=\"button\" @click=\"$router.push('/mission-workspace')\">워크스페이스 열기</button>\n      </article>\n      <article class=\"help-page__card\">\n        <span>03</span>\n        <h2>검사와 피드백</h2>\n        <p>테스트가 실패하면 실패한 요구사항과 AI 분석을 확인하고 다음 수정 방향을 잡으세요.</p>\n        <button type=\"button\" @click=\"$router.push('/frontend-ai-feedback')\">AI 피드백 보기</button>\n      </article>\n    </section>\n    <AppFooter />\n  </main>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getNavigation } from '../api/codemong'\n\nexport default {\n  name: 'HelpPage',\n  components: {\n    AppFooter,\n    AppHeader,\n  },\n  data() {\n    return {\n      navigation: [],\n    }\n  },\n  async created() {\n    this.navigation = await getNavigation()\n  },\n  metaInfo: {\n    title: '도움말',\n    meta: [\n      {\n        property: 'og:title',\n        content: '도움말',\n      },\n    ],\n  },\n}\n</script>\n\n<style scoped>\n@import '../styles/views/help-page.css';\n</style>\n"],"mappings":"AAqCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,aAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAJ,SAAA;IACAC;EACA;EACAI,KAAA;IACA;MACAC,UAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA,KAAAD,UAAA,SAAAJ,aAAA;EACA;EACAM,QAAA;IACAC,KAAA;IACAC,IAAA,GACA;MACAC,QAAA;MACAC,OAAA;IACA;EAEA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}