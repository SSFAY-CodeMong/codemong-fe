{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getProjectSteps, getSelectedProject, saveProjectStartRequest } from '../api/codemong';\nexport default {\n  name: 'ProjectSetupPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      project: null,\n      steps: [],\n      startStep: 1,\n      message: '',\n      needsLogin: false\n    };\n  },\n  computed: {\n    track() {\n      return this.project && this.project.type || 'BE';\n    },\n    trackLabel() {\n      return this.track === 'FE' ? 'Frontend' : 'Backend';\n    }\n  },\n  async created() {\n    this.project = getSelectedProject();\n    if (!this.project) {\n      this.$router.replace('/projects');\n      return;\n    }\n    this.steps = await getProjectSteps(this.project.id);\n  },\n  methods: {\n    start() {\n      this.message = '';\n      this.needsLogin = false;\n      saveProjectStartRequest({\n        project: this.project,\n        payload: {\n          startStep: this.startStep,\n          track: this.track\n        }\n      });\n      this.$router.push('/project-initializing');\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getProjectSteps","getSelectedProject","saveProjectStartRequest","name","components","data","project","steps","startStep","message","needsLogin","computed","track","type","trackLabel","created","$router","replace","id","methods","start","payload","push"],"sources":["src/views/project-setup-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"projects\" />\n    <main class=\"page setup-page\">\n      <section class=\"setup-header\">\n        <div>\n          <span class=\"badge\">{{ trackLabel }}</span>\n          <h1>시작 스텝 선택</h1>\n          <p v-if=\"project\">\n            {{ project.name }} 프로젝트의 시작 지점을 고르면 GitHub 저장소 생성과 스타터 코드 복사가 이어집니다.\n          </p>\n        </div>\n        <div class=\"setup-summary\" v-if=\"project\">\n          <strong>{{ project.name }}</strong>\n          <span>{{ project.description }}</span>\n        </div>\n      </section>\n\n      <section class=\"setup-grid\">\n        <article\n          v-for=\"step in steps\"\n          :key=\"step.step\"\n          class=\"step-card\"\n          :class=\"{ selected: startStep === step.step }\"\n          @click=\"startStep = step.step\"\n        >\n          <div class=\"step-card__number\">{{ step.stepId }}</div>\n          <div>\n            <h2>{{ step.title }}</h2>\n            <p>{{ step.description }}</p>\n          </div>\n        </article>\n      </section>\n\n      <aside class=\"setup-action panel\">\n        <div>\n          <h2>생성 요청</h2>\n          <p>트랙은 프로젝트 타입 기준으로 고정됩니다. 선택된 스텝부터 브랜치와 starter 코드가 준비됩니다.</p>\n        </div>\n        <dl>\n          <div>\n            <dt>시작 스텝</dt>\n            <dd>step{{ String(startStep).padStart(2, '0') }}</dd>\n          </div>\n          <div>\n            <dt>트랙</dt>\n            <dd>{{ trackLabel }}</dd>\n          </div>\n        </dl>\n        <button class=\"primary\" type=\"button\" :disabled=\"!project\" @click=\"start\">\n          프로젝트 생성 시작\n        </button>\n        <p v-if=\"message\" class=\"status fail\">{{ message }}</p>\n        <button v-if=\"needsLogin\" class=\"secondary\" type=\"button\" @click=\"$router.push('/login')\">\n          GitHub 로그인으로 이동\n        </button>\n      </aside>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getProjectSteps, getSelectedProject, saveProjectStartRequest } from '../api/codemong'\n\nexport default {\n  name: 'ProjectSetupPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      project: null,\n      steps: [],\n      startStep: 1,\n      message: '',\n      needsLogin: false,\n    }\n  },\n  computed: {\n    track() {\n      return (this.project && this.project.type) || 'BE'\n    },\n    trackLabel() {\n      return this.track === 'FE' ? 'Frontend' : 'Backend'\n    },\n  },\n  async created() {\n    this.project = getSelectedProject()\n    if (!this.project) {\n      this.$router.replace('/projects')\n      return\n    }\n    this.steps = await getProjectSteps(this.project.id)\n  },\n  methods: {\n    start() {\n      this.message = ''\n      this.needsLogin = false\n      saveProjectStartRequest({\n        project: this.project,\n        payload: { startStep: this.startStep, track: this.track },\n      })\n      this.$router.push('/project-initializing')\n    },\n  },\n}\n</script>\n"],"mappings":";AA+DA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,eAAA,EAAAC,kBAAA,EAAAC,uBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAN,SAAA;IAAAC;EAAA;EACAM,KAAA;IACA;MACAC,OAAA;MACAC,KAAA;MACAC,SAAA;MACAC,OAAA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACAC,MAAA;MACA,YAAAN,OAAA,SAAAA,OAAA,CAAAO,IAAA;IACA;IACAC,WAAA;MACA,YAAAF,KAAA;IACA;EACA;EACA,MAAAG,QAAA;IACA,KAAAT,OAAA,GAAAL,kBAAA;IACA,UAAAK,OAAA;MACA,KAAAU,OAAA,CAAAC,OAAA;MACA;IACA;IACA,KAAAV,KAAA,SAAAP,eAAA,MAAAM,OAAA,CAAAY,EAAA;EACA;EACAC,OAAA;IACAC,MAAA;MACA,KAAAX,OAAA;MACA,KAAAC,UAAA;MACAR,uBAAA;QACAI,OAAA,OAAAA,OAAA;QACAe,OAAA;UAAAb,SAAA,OAAAA,SAAA;UAAAI,KAAA,OAAAA;QAAA;MACA;MACA,KAAAI,OAAA,CAAAM,IAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}