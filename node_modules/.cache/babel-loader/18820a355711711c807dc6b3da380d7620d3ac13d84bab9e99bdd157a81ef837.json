{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getCodeCheckStatus, getSavedCheckId } from '../api/codemong';\nexport default {\n  name: 'InspectionRunningPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      checkId: getSavedCheckId(),\n      status: 'RUNNING',\n      failedTests: [],\n      timer: null\n    };\n  },\n  computed: {\n    passed() {\n      return this.status === 'PASSED';\n    },\n    failed() {\n      return this.status === 'FAILED' || this.status === 'ERROR';\n    }\n  },\n  created() {\n    if (!this.checkId) {\n      this.$router.replace('/mission-workspace');\n      return;\n    }\n    this.poll();\n    this.timer = window.setInterval(this.poll, 3000);\n  },\n  beforeDestroy() {\n    window.clearInterval(this.timer);\n  },\n  methods: {\n    async poll() {\n      const result = await getCodeCheckStatus(this.checkId);\n      this.status = result.status;\n      this.failedTests = result.failedTests || [];\n      if (this.passed || this.failed) window.clearInterval(this.timer);\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getCodeCheckStatus","getSavedCheckId","name","components","data","checkId","status","failedTests","timer","computed","passed","failed","created","$router","replace","poll","window","setInterval","beforeDestroy","clearInterval","methods","result"],"sources":["src/views/inspection-running-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mission\" />\n    <main class=\"page\">\n      <section class=\"panel\">\n        <h1>검사 실행 중</h1>\n        <p>checkId: {{ checkId }}</p>\n        <p>\n          상태:\n          <span class=\"status\" :class=\"{ ok: passed, fail: failed }\">{{ status }}</span>\n        </p>\n        <ul v-if=\"failedTests.length\" class=\"list\">\n          <li v-for=\"test in failedTests\" :key=\"test\">{{ test }}</li>\n        </ul>\n        <div class=\"toolbar\">\n          <button class=\"secondary\" type=\"button\" @click=\"poll\">새로고침</button>\n          <button v-if=\"passed\" class=\"primary\" type=\"button\" @click=\"$router.push('/mission-passed')\">결과 보기</button>\n          <button v-if=\"failed\" class=\"danger\" type=\"button\" @click=\"$router.push('/mission-failed')\">실패 확인</button>\n        </div>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getCodeCheckStatus, getSavedCheckId } from '../api/codemong'\n\nexport default {\n  name: 'InspectionRunningPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      checkId: getSavedCheckId(),\n      status: 'RUNNING',\n      failedTests: [],\n      timer: null,\n    }\n  },\n  computed: {\n    passed() {\n      return this.status === 'PASSED'\n    },\n    failed() {\n      return this.status === 'FAILED' || this.status === 'ERROR'\n    },\n  },\n  created() {\n    if (!this.checkId) {\n      this.$router.replace('/mission-workspace')\n      return\n    }\n    this.poll()\n    this.timer = window.setInterval(this.poll, 3000)\n  },\n  beforeDestroy() {\n    window.clearInterval(this.timer)\n  },\n  methods: {\n    async poll() {\n      const result = await getCodeCheckStatus(this.checkId)\n      this.status = result.status\n      this.failedTests = result.failedTests || []\n      if (this.passed || this.failed) window.clearInterval(this.timer)\n    },\n  },\n}\n</script>\n"],"mappings":"AA0BA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,kBAAA,EAAAC,eAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAL,SAAA;IAAAC;EAAA;EACAK,KAAA;IACA;MACAC,OAAA,EAAAJ,eAAA;MACAK,MAAA;MACAC,WAAA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACAC,OAAA;MACA,YAAAJ,MAAA;IACA;IACAK,OAAA;MACA,YAAAL,MAAA,sBAAAA,MAAA;IACA;EACA;EACAM,QAAA;IACA,UAAAP,OAAA;MACA,KAAAQ,OAAA,CAAAC,OAAA;MACA;IACA;IACA,KAAAC,IAAA;IACA,KAAAP,KAAA,GAAAQ,MAAA,CAAAC,WAAA,MAAAF,IAAA;EACA;EACAG,cAAA;IACAF,MAAA,CAAAG,aAAA,MAAAX,KAAA;EACA;EACAY,OAAA;IACA,MAAAL,KAAA;MACA,MAAAM,MAAA,SAAArB,kBAAA,MAAAK,OAAA;MACA,KAAAC,MAAA,GAAAe,MAAA,CAAAf,MAAA;MACA,KAAAC,WAAA,GAAAc,MAAA,CAAAd,WAAA;MACA,SAAAG,MAAA,SAAAC,MAAA,EAAAK,MAAA,CAAAG,aAAA,MAAAX,KAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}