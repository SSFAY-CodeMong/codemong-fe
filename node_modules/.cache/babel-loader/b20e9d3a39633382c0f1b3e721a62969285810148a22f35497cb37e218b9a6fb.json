{"ast":null,"code":"export default {\n  name: 'MainPage',\n  props: {},\n  metaInfo: {\n    title: 'Codemong',\n    meta: [{\n      property: 'og:title',\n      content: 'Codemong'\n    }]\n  }\n};","map":{"version":3,"names":["name","props","metaInfo","title","meta","property","content"],"sources":["src/views/main-page.vue"],"sourcesContent":["<template>\n  <main class=\"main-page\">\n    <header class=\"main-page__header\">\n      <div class=\"main-page__header-inner\">\n        <button class=\"main-page__brand\" type=\"button\" @click=\"$router.push('/')\">\n          Codemong\n        </button>\n        <nav class=\"main-page__nav\" aria-label=\"주요 메뉴\">\n          <button type=\"button\" @click=\"$router.push('/projects')\">프로젝트</button>\n          <button type=\"button\" @click=\"$router.push('/mission-workspace')\">내 미션</button>\n          <button type=\"button\" @click=\"$router.push('/mission-progress')\">진행 현황</button>\n          <button type=\"button\" @click=\"$router.push('/help')\">도움말</button>\n        </nav>\n        <div class=\"main-page__actions\">\n          <button class=\"main-page__icon-button\" type=\"button\" @click=\"$router.push('/mission-workspace')\" aria-label=\"내 미션\">\n            <span>◎</span>\n          </button>\n          <button class=\"main-page__primary\" type=\"button\" @click=\"$router.push('/login')\">\n            GitHub로 시작하기\n          </button>\n        </div>\n      </div>\n    </header>\n\n    <section class=\"main-page__hero\">\n      <div class=\"main-page__hero-copy\">\n        <p class=\"main-page__eyebrow\">실전 프로젝트 기반 학습</p>\n        <h1>\n          시작이 부담스러운 프로젝트,\n          <span>Codemong에서 바로 완성하세요</span>\n        </h1>\n        <p class=\"main-page__lead\">\n          프로젝트 선택부터 GitHub 레포지토리 생성, 미션 진행, 테스트 검사, AI 피드백까지 하나의 흐름으로 연결합니다.\n        </p>\n        <div class=\"main-page__hero-actions\">\n          <button class=\"main-page__primary main-page__primary--large\" type=\"button\" @click=\"$router.push('/projects')\">\n            프로젝트 시작하기\n          </button>\n          <button class=\"main-page__secondary\" type=\"button\" @click=\"$router.push('/help')\">\n            진행 방식 보기\n          </button>\n        </div>\n      </div>\n      <div class=\"main-page__hero-panel\" aria-label=\"Codemong 진행 예시\">\n        <div class=\"main-page__panel-top\">\n          <span>오늘의 미션</span>\n          <strong>3 / 10 단계</strong>\n        </div>\n        <div class=\"main-page__progress\">\n          <span></span>\n        </div>\n        <div class=\"main-page__checks\">\n          <div>\n            <strong>요구사항 분석</strong>\n            <span>spec.md 기반 체크리스트 생성</span>\n          </div>\n          <div>\n            <strong>자동 검사</strong>\n            <span>GitHub Actions와 테스트 결과 수집</span>\n          </div>\n          <div>\n            <strong>AI 피드백</strong>\n            <span>실패 원인과 수정 방향 제안</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"main-page__section\">\n      <div class=\"main-page__section-heading\">\n        <p>학습 흐름</p>\n        <h2>프로젝트를 끝까지 밀고 가는 데 필요한 화면을 모두 연결했습니다</h2>\n      </div>\n      <div class=\"main-page__cards\">\n        <article>\n          <span>01</span>\n          <h3>프로젝트 선택</h3>\n          <p>난이도, 기술 스택, 단계 수를 보고 지금 도전할 프로젝트를 고릅니다.</p>\n        </article>\n        <article>\n          <span>02</span>\n          <h3>미션 진행</h3>\n          <p>요구사항과 예시 코드를 확인하고 GitHub에 작업 내용을 반영합니다.</p>\n        </article>\n        <article>\n          <span>03</span>\n          <h3>검사와 AI 분석</h3>\n          <p>테스트 실패 지점과 수정 제안을 확인하며 다음 단계로 넘어갑니다.</p>\n        </article>\n      </div>\n    </section>\n\n    <section class=\"main-page__metrics\">\n      <div>\n        <strong>10+</strong>\n        <span>단계별 미션</span>\n      </div>\n      <div>\n        <strong>자동</strong>\n        <span>레포지토리 생성</span>\n      </div>\n      <div>\n        <strong>AI</strong>\n        <span>실패 원인 분석</span>\n      </div>\n    </section>\n\n    <footer class=\"main-page__footer\">\n      <div class=\"main-page__footer-inner\">\n        <strong>Codemong</strong>\n        <span>© 2024 Codemong. GitHub 공식 API 연동을 사용합니다.</span>\n        <div>\n          <button type=\"button\" @click=\"$router.push('/help')\">이용약관</button>\n          <button type=\"button\" @click=\"$router.push('/help')\">개인정보 처리방침</button>\n        </div>\n      </div>\n    </footer>\n  </main>\n</template>\n\n<script>\nexport default {\n  name: 'MainPage',\n  props: {},\n  metaInfo: {\n    title: 'Codemong',\n    meta: [\n      {\n        property: 'og:title',\n        content: 'Codemong',\n      },\n    ],\n  },\n}\n</script>\n\n<style scoped>\n@import '../styles/views/main-page.css';\n</style>\n"],"mappings":"AAyHA;EACAA,IAAA;EACAC,KAAA;EACAC,QAAA;IACAC,KAAA;IACAC,IAAA,GACA;MACAC,QAAA;MACAC,OAAA;IACA;EAEA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}