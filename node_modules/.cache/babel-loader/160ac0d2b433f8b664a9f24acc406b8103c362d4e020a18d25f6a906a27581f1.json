{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getSavedRepository, moveNextStep } from '../api/codemong';\nexport default {\n  name: 'NextStepLoadingPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      repository: getSavedRepository(),\n      loading: false,\n      started: false,\n      created: false,\n      error: false,\n      message: '통과한 브랜치를 기준으로 다음 스텝 브랜치를 생성합니다.'\n    };\n  },\n  created() {\n    this.next();\n  },\n  methods: {\n    async next() {\n      if (!this.repository) {\n        this.error = true;\n        this.message = '선택된 저장소가 없습니다. 미션 화면에서 저장소를 다시 선택하세요.';\n        return;\n      }\n      this.loading = true;\n      this.started = true;\n      this.created = false;\n      this.error = false;\n      this.message = '다음 스텝 브랜치를 생성하는 중입니다. 잠시만 기다려주세요.';\n      try {\n        await moveNextStep(this.repository.repositoryId);\n        this.created = true;\n        this.message = '다음 스텝 브랜치가 생성되었습니다. 미션 화면으로 이동합니다.';\n        window.setTimeout(() => this.$router.push('/mission-workspace'), 700);\n      } catch (error) {\n        this.error = true;\n        this.message = error.message;\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getSavedRepository","moveNextStep","name","components","data","repository","loading","started","created","error","message","next","methods","repositoryId","window","setTimeout","$router","push"],"sources":["src/views/next-step-loading-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mission\" />\n    <main class=\"page loading-page\">\n      <section class=\"loading-panel next-step-panel\">\n        <div class=\"loader-orbit next-step-loader\" :class=\"{ failed: error }\">\n          <span></span>\n          <span></span>\n          <span></span>\n        </div>\n        <div>\n          <span class=\"badge\">{{ loading ? 'CREATING' : error ? 'FAILED' : 'READY' }}</span>\n          <h1>다음 스텝 준비</h1>\n          <p>{{ message }}</p>\n        </div>\n        <ol class=\"inspection-steps\">\n          <li :class=\"{ active: loading, done: started }\">현재 통과 브랜치 확인</li>\n          <li :class=\"{ active: loading, done: created }\">다음 스텝 브랜치 생성</li>\n          <li :class=\"{ active: created, done: created }\">미션 화면 이동 준비</li>\n        </ol>\n        <div class=\"toolbar\">\n          <button v-if=\"error\" class=\"primary\" type=\"button\" @click=\"next\">다시 생성</button>\n          <button class=\"secondary\" type=\"button\" @click=\"$router.push('/mission-workspace')\">미션으로 이동</button>\n        </div>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getSavedRepository, moveNextStep } from '../api/codemong'\n\nexport default {\n  name: 'NextStepLoadingPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      repository: getSavedRepository(),\n      loading: false,\n      started: false,\n      created: false,\n      error: false,\n      message: '통과한 브랜치를 기준으로 다음 스텝 브랜치를 생성합니다.',\n    }\n  },\n  created() {\n    this.next()\n  },\n  methods: {\n    async next() {\n      if (!this.repository) {\n        this.error = true\n        this.message = '선택된 저장소가 없습니다. 미션 화면에서 저장소를 다시 선택하세요.'\n        return\n      }\n      this.loading = true\n      this.started = true\n      this.created = false\n      this.error = false\n      this.message = '다음 스텝 브랜치를 생성하는 중입니다. 잠시만 기다려주세요.'\n      try {\n        await moveNextStep(this.repository.repositoryId)\n        this.created = true\n        this.message = '다음 스텝 브랜치가 생성되었습니다. 미션 화면으로 이동합니다.'\n        window.setTimeout(() => this.$router.push('/mission-workspace'), 700)\n      } catch (error) {\n        this.error = true\n        this.message = error.message\n      } finally {\n        this.loading = false\n      }\n    },\n  },\n}\n</script>\n"],"mappings":";AA+BA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,kBAAA,EAAAC,YAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAL,SAAA;IAAAC;EAAA;EACAK,KAAA;IACA;MACAC,UAAA,EAAAL,kBAAA;MACAM,OAAA;MACAC,OAAA;MACAC,OAAA;MACAC,KAAA;MACAC,OAAA;IACA;EACA;EACAF,QAAA;IACA,KAAAG,IAAA;EACA;EACAC,OAAA;IACA,MAAAD,KAAA;MACA,UAAAN,UAAA;QACA,KAAAI,KAAA;QACA,KAAAC,OAAA;QACA;MACA;MACA,KAAAJ,OAAA;MACA,KAAAC,OAAA;MACA,KAAAC,OAAA;MACA,KAAAC,KAAA;MACA,KAAAC,OAAA;MACA;QACA,MAAAT,YAAA,MAAAI,UAAA,CAAAQ,YAAA;QACA,KAAAL,OAAA;QACA,KAAAE,OAAA;QACAI,MAAA,CAAAC,UAAA,YAAAC,OAAA,CAAAC,IAAA;MACA,SAAAR,KAAA;QACA,KAAAA,KAAA;QACA,KAAAC,OAAA,GAAAD,KAAA,CAAAC,OAAA;MACA;QACA,KAAAJ,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}