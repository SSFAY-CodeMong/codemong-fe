{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getProjects, saveSelectedProject } from '../api/codemong';\nexport default {\n  name: 'ProjectsPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      projects: [],\n      selected: null\n    };\n  },\n  async created() {\n    this.projects = await getProjects();\n    this.selected = this.projects[0] || null;\n  },\n  methods: {\n    select(project) {\n      this.selected = project;\n    },\n    goSetup() {\n      saveSelectedProject(this.selected);\n      this.$router.push('/project-setup');\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getProjects","saveSelectedProject","name","components","data","projects","selected","created","methods","select","project","goSetup","$router","push"],"sources":["src/views/projects-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"projects\" />\n    <main class=\"page layout\">\n      <section>\n        <h1>프로젝트</h1>\n        <p>진행할 프로젝트를 선택하세요.</p>\n        <div class=\"grid\">\n          <article\n            v-for=\"project in projects\"\n            :key=\"project.id\"\n            class=\"card\"\n            :class=\"{ selected: selected && selected.id === project.id }\"\n            @click=\"select(project)\"\n          >\n            <span class=\"badge\">{{ project.category }}</span>\n            <h2>{{ project.title || project.name }}</h2>\n            <p>{{ project.description }}</p>\n            <p class=\"muted\">{{ project.steps }} steps · {{ project.difficulty }}</p>\n          </article>\n        </div>\n      </section>\n      <aside class=\"panel\" v-if=\"selected\">\n        <h2>{{ selected.title || selected.name }}</h2>\n        <p>{{ selected.description }}</p>\n        <h3>목표</h3>\n        <ul class=\"list\">\n          <li v-for=\"goal in selected.goals\" :key=\"goal\">{{ goal }}</li>\n        </ul>\n        <h3>스택</h3>\n        <p>{{ selected.stacks.join(', ') }}</p>\n        <button class=\"primary\" type=\"button\" @click=\"goSetup\">시작 스텝 선택</button>\n      </aside>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getProjects, saveSelectedProject } from '../api/codemong'\n\nexport default {\n  name: 'ProjectsPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      projects: [],\n      selected: null,\n    }\n  },\n  async created() {\n    this.projects = await getProjects()\n    this.selected = this.projects[0] || null\n  },\n  methods: {\n    select(project) {\n      this.selected = project\n    },\n    goSetup() {\n      saveSelectedProject(this.selected)\n      this.$router.push('/project-setup')\n    },\n  },\n}\n</script>\n"],"mappings":";AAuCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,WAAA,EAAAC,mBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAL,SAAA;IAAAC;EAAA;EACAK,KAAA;IACA;MACAC,QAAA;MACAC,QAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA,KAAAF,QAAA,SAAAL,WAAA;IACA,KAAAM,QAAA,QAAAD,QAAA;EACA;EACAG,OAAA;IACAC,OAAAC,OAAA;MACA,KAAAJ,QAAA,GAAAI,OAAA;IACA;IACAC,QAAA;MACAV,mBAAA,MAAAK,QAAA;MACA,KAAAM,OAAA,CAAAC,IAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}