{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nexport default {\n  name: 'MainPage',\n  components: {\n    AppFooter,\n    AppHeader\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","name","components"],"sources":["src/views/main-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader />\n    <main class=\"page\">\n      <section class=\"hero\">\n        <div>\n          <span class=\"badge\">GitHub 기반 실습</span>\n          <h1>Codemong</h1>\n          <p>프로젝트를 선택하고 GitHub 저장소를 만든 뒤, 단계별 요구사항을 구현하고 검사 결과를 확인합니다.</p>\n          <div class=\"toolbar\">\n            <button class=\"primary\" type=\"button\" @click=\"$router.push('/projects')\">프로젝트 시작</button>\n            <button class=\"secondary\" type=\"button\" @click=\"$router.push('/mission-progress')\">진행 현황</button>\n          </div>\n        </div>\n        <div class=\"panel\">\n          <h2>학습 흐름</h2>\n          <ul class=\"list\">\n            <li>프로젝트와 시작 스텝 선택</li>\n            <li>GitHub 학습 저장소 자동 생성</li>\n            <li>비동기 검사 실행 및 결과 확인</li>\n            <li>통과 후 다음 스텝 이동</li>\n          </ul>\n        </div>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\n\nexport default {\n  name: 'MainPage',\n  components: { AppFooter, AppHeader },\n}\n</script>\n"],"mappings":"AA8BA,OAAAA,SAAA;AACA,OAAAC,SAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAH,SAAA;IAAAC;EAAA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}