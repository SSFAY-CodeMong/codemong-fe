{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'AppHeader',\n  props: {\n    activePage: {\n      type: String,\n      default: 'home'\n    },\n    brandName: {\n      type: String,\n      default: 'Codemong'\n    },\n    ctaLabel: {\n      type: String,\n      default: 'GitHub로 시작하기'\n    },\n    navigation: {\n      type: Array,\n      default: function _default() {\n        return [{\n          key: 'projects',\n          label: '프로젝트',\n          path: '/projects'\n        }, {\n          key: 'mission',\n          label: '내 미션',\n          path: '/mission-workspace'\n        }, {\n          key: 'progress',\n          label: '진행 현황',\n          path: '/mission-progress'\n        }, {\n          key: 'help',\n          label: '도움말',\n          path: '/help'\n        }];\n      }\n    }\n  },\n  methods: {\n    go: function go(path) {\n      if (this.$route && this.$route.path === path) return;\n      this.$router.push(path);\n    }\n  }\n};","map":{"version":3,"names":["name","props","activePage","type","String","default","brandName","ctaLabel","navigation","Array","key","label","path","methods","go","$route","$router","push"],"sources":["src/components/AppHeader.vue"],"sourcesContent":["<template>\r\n  <header class=\"codemong-header\">\r\n    <div class=\"codemong-header__inner\">\r\n      <button class=\"codemong-header__brand\" type=\"button\" @click=\"go('/')\">\r\n        {{ brandName }}\r\n      </button>\r\n      <nav class=\"codemong-header__nav\" aria-label=\"주요 메뉴\">\r\n        <button\r\n          v-for=\"item in navigation\"\r\n          :key=\"item.path\"\r\n          type=\"button\"\r\n          :class=\"{ 'is-active': item.key === activePage }\"\r\n          @click=\"go(item.path)\"\r\n        >\r\n          {{ item.label }}\r\n        </button>\r\n      </nav>\r\n      <div class=\"codemong-header__actions\">\r\n        <button\r\n          class=\"codemong-header__icon-button\"\r\n          type=\"button\"\r\n          aria-label=\"내 미션\"\r\n          @click=\"go('/mission-workspace')\"\r\n        >\r\n          <span>◎</span>\r\n        </button>\r\n        <button class=\"codemong-header__primary\" type=\"button\" @click=\"go('/login')\">\r\n          {{ ctaLabel }}\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </header>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'AppHeader',\r\n  props: {\r\n    activePage: {\r\n      type: String,\r\n      default: 'home',\r\n    },\r\n    brandName: {\r\n      type: String,\r\n      default: 'Codemong',\r\n    },\r\n    ctaLabel: {\r\n      type: String,\r\n      default: 'GitHub로 시작하기',\r\n    },\r\n    navigation: {\r\n      type: Array,\r\n      default: () => [\r\n        { key: 'projects', label: '프로젝트', path: '/projects' },\r\n        { key: 'mission', label: '내 미션', path: '/mission-workspace' },\r\n        { key: 'progress', label: '진행 현황', path: '/mission-progress' },\r\n        { key: 'help', label: '도움말', path: '/help' },\r\n      ],\r\n    },\r\n  },\r\n  methods: {\r\n    go(path) {\r\n      if (this.$route && this.$route.path === path) return\r\n      this.$router.push(path)\r\n    },\r\n  },\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@import '../styles/components/app-header.css';\r\n</style>\r\n"],"mappings":";AAmCA;EACAA,IAAA;EACAC,KAAA;IACAC,UAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAC,SAAA;MACAH,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAE,QAAA;MACAJ,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAG,UAAA;MACAL,IAAA,EAAAM,KAAA;MACAJ,OAAA,WAAAA,SAAA;QAAA,QACA;UAAAK,GAAA;UAAAC,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAF,GAAA;UAAAC,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAF,GAAA;UAAAC,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAF,GAAA;UAAAC,KAAA;UAAAC,IAAA;QAAA,EACA;MAAA;IACA;EACA;EACAC,OAAA;IACAC,EAAA,WAAAA,GAAAF,IAAA;MACA,SAAAG,MAAA,SAAAA,MAAA,CAAAH,IAAA,KAAAA,IAAA;MACA,KAAAI,OAAA,CAAAC,IAAA,CAAAL,IAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}