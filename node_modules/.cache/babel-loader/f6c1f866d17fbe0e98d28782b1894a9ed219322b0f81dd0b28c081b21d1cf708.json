{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getMailContent, getMailContents, getMailDashboard, getRandomMailQuestion, sendTestMail, submitMailAnswer, updateMailSubscription } from '../api/codemong';\nexport default {\n  name: 'MailServicePage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      loading: false,\n      sending: false,\n      hasError: false,\n      message: '',\n      subscription: {\n        enabled: false,\n        email: ''\n      },\n      enabledDraft: false,\n      emailDraft: '',\n      previewQuestion: null,\n      previewContent: null,\n      recentLogs: [],\n      question: null,\n      answerContent: '',\n      codeContent: '',\n      answerResult: null,\n      evaluating: false,\n      contents: [],\n      openedContent: null\n    };\n  },\n  created() {\n    this.loadDashboard();\n    this.loadQuestion();\n    this.loadContents();\n  },\n  methods: {\n    async loadDashboard() {\n      this.loading = true;\n      this.message = '';\n      this.hasError = false;\n      try {\n        const dashboard = await getMailDashboard();\n        this.subscription = dashboard.subscription || {\n          enabled: false,\n          email: ''\n        };\n        this.enabledDraft = this.subscription.enabled;\n        this.emailDraft = this.subscription.email || '';\n        this.previewQuestion = dashboard.previewQuestion;\n        this.previewContent = dashboard.previewContent;\n        this.recentLogs = dashboard.recentLogs || [];\n      } catch (error) {\n        this.hasError = true;\n        this.message = error.message;\n      } finally {\n        this.loading = false;\n      }\n    },\n    async loadQuestion() {\n      this.answerResult = null;\n      this.question = await getRandomMailQuestion();\n    },\n    async submitAnswer() {\n      if (!this.question) return;\n      this.evaluating = true;\n      try {\n        this.answerResult = await submitMailAnswer(this.question.id, {\n          content: this.answerContent,\n          codeContent: this.codeContent\n        });\n      } catch (error) {\n        this.answerResult = {\n          score: 0,\n          feedback: error.message\n        };\n      } finally {\n        this.evaluating = false;\n      }\n    },\n    async loadContents() {\n      this.contents = await getMailContents();\n    },\n    async openContent(content) {\n      this.openedContent = await getMailContent(content.id);\n    },\n    async saveSubscription() {\n      if (this.enabledDraft && !this.subscription.email && !this.emailDraft) {\n        this.hasError = true;\n        this.message = '메일을 받을 이메일을 입력하세요.';\n        return;\n      }\n      try {\n        this.subscription = await updateMailSubscription(this.enabledDraft, this.emailDraft);\n        this.enabledDraft = this.subscription.enabled;\n        this.emailDraft = this.subscription.email || '';\n        this.hasError = false;\n        this.message = this.subscription.enabled ? '메일 구독이 켜졌습니다.' : '메일 구독이 꺼졌습니다.';\n      } catch (error) {\n        this.hasError = true;\n        this.message = error.message;\n        this.enabledDraft = this.subscription.enabled;\n      }\n    },\n    async sendTest() {\n      this.sending = true;\n      this.message = '';\n      try {\n        const log = await sendTestMail();\n        this.hasError = !log.success;\n        this.message = log.message;\n        await this.loadDashboard();\n      } catch (error) {\n        this.hasError = true;\n        this.message = error.message;\n      } finally {\n        this.sending = false;\n      }\n    },\n    formatDate(value) {\n      if (!value) return '';\n      return new Date(value).toLocaleString();\n    }\n  },\n  computed: {\n    requiresEmailInput() {\n      return this.enabledDraft && !this.subscription.email;\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getMailContent","getMailContents","getMailDashboard","getRandomMailQuestion","sendTestMail","submitMailAnswer","updateMailSubscription","name","components","data","loading","sending","hasError","message","subscription","enabled","email","enabledDraft","emailDraft","previewQuestion","previewContent","recentLogs","question","answerContent","codeContent","answerResult","evaluating","contents","openedContent","created","loadDashboard","loadQuestion","loadContents","methods","dashboard","error","submitAnswer","id","content","score","feedback","openContent","saveSubscription","sendTest","log","success","formatDate","value","Date","toLocaleString","computed","requiresEmailInput"],"sources":["src/views/mail-service-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mail\" />\n    <main class=\"page mail-page\">\n      <section class=\"mail-hero\">\n        <div>\n          <span class=\"badge\">DevDaily for Codemong</span>\n          <h1>메일서비스</h1>\n          <p>Codemong 계정 이메일로 개발 질문을 주기적으로 받아볼 수 있습니다. 현재 테스트 설정은 10분마다 랜덤 질문을 발송합니다.</p>\n        </div>\n        <div class=\"mail-status\" :class=\"{ active: subscription.enabled }\">\n          <strong>{{ subscription.enabled ? '구독 중' : '구독 꺼짐' }}</strong>\n          <span>{{ subscription.email || '이메일 없음' }}</span>\n        </div>\n      </section>\n\n      <section class=\"mail-layout\">\n        <article class=\"panel mail-control\">\n          <div class=\"section-head\">\n            <div>\n              <h2>발송 설정</h2>\n              <p>Spring Batch가 10분마다 활성 구독자에게 랜덤 질문을 발송합니다.</p>\n            </div>\n          </div>\n          <label class=\"toggle-row\">\n            <input type=\"checkbox\" v-model=\"enabledDraft\" @change=\"saveSubscription\" />\n            <span>메일 발송 받기</span>\n          </label>\n          <form v-if=\"requiresEmailInput\" class=\"form mail-email-form\" @submit.prevent=\"saveSubscription\">\n            <label>\n              수신 이메일\n              <input v-model.trim=\"emailDraft\" type=\"email\" placeholder=\"you@example.com\" />\n            </label>\n            <p>GitHub 계정에서 이메일을 가져오지 못했습니다. 메일을 받을 주소를 먼저 입력하세요.</p>\n          </form>\n          <div class=\"toolbar\">\n            <button class=\"primary\" type=\"button\" @click=\"sendTest\" :disabled=\"sending\">\n              {{ sending ? '테스트 발송 중' : '테스트 메일 보내기' }}\n            </button>\n            <button class=\"secondary\" type=\"button\" @click=\"loadDashboard\" :disabled=\"loading\">새로고침</button>\n          </div>\n          <p v-if=\"message\" class=\"status\" :class=\"{ fail: hasError, ok: !hasError }\">{{ message }}</p>\n        </article>\n\n        <article class=\"panel\">\n          <h2>메일 콘텐츠 미리보기</h2>\n          <div v-if=\"previewContent\" class=\"mail-question-card\">\n            <span class=\"badge\">{{ previewContent.track }}</span>\n            <h3>{{ previewContent.title }}</h3>\n            <button class=\"secondary small\" type=\"button\" @click=\"openContent(previewContent)\">팝업으로 보기</button>\n          </div>\n          <p v-else>아직 등록된 메일 콘텐츠가 없습니다.</p>\n        </article>\n      </section>\n\n      <section class=\"mail-layout\">\n        <article class=\"panel mail-solve-panel\">\n          <div class=\"section-head\">\n            <div>\n              <h2>문제 풀기</h2>\n              <p>DevDaily의 답변 제출/AI 피드백 흐름을 Codemong 메일서비스에 붙였습니다.</p>\n            </div>\n            <button class=\"secondary small\" type=\"button\" @click=\"loadQuestion\">랜덤 문제</button>\n          </div>\n          <div v-if=\"question\" class=\"mail-question-card\">\n            <span class=\"badge\">{{ question.category }} · {{ question.difficulty }} · {{ question.questionType }}</span>\n            <h3>{{ question.title }}</h3>\n            <p>{{ question.content }}</p>\n          </div>\n          <form v-if=\"question\" class=\"form\" @submit.prevent=\"submitAnswer\">\n            <textarea v-model=\"answerContent\" rows=\"5\" placeholder=\"설명 답변을 입력하세요.\"></textarea>\n            <textarea\n              v-model=\"codeContent\"\n              rows=\"8\"\n              class=\"code-textarea\"\n              placeholder=\"코드로 푸는 문제라면 여기에 코드를 입력하세요.\"\n            ></textarea>\n            <button class=\"primary\" type=\"submit\" :disabled=\"evaluating\">\n              {{ evaluating ? 'AI 피드백 생성 중' : '답변 제출' }}\n            </button>\n          </form>\n          <div v-if=\"answerResult\" class=\"answer-box mail-feedback-box\">\n            <strong>{{ answerResult.score }}점</strong>\n            <div>{{ answerResult.feedback }}</div>\n          </div>\n        </article>\n\n        <article class=\"panel\">\n          <div class=\"section-head\">\n            <div>\n              <h2>메일 콘텐츠 목록</h2>\n              <p>md 파일을 팝업으로 확인할 수 있습니다.</p>\n            </div>\n          </div>\n          <ul class=\"mail-content-list\">\n            <li v-for=\"content in contents\" :key=\"content.id\">\n              <button type=\"button\" @click=\"openContent(content)\">\n                <strong>{{ content.title }}</strong>\n                <span>{{ content.track }}</span>\n              </button>\n            </li>\n          </ul>\n        </article>\n      </section>\n\n      <section class=\"panel\">\n        <div class=\"section-head\">\n          <div>\n            <h2>최근 발송 로그</h2>\n            <p>SMTP 설정이 없으면 실제 발송은 스킵되고 로그만 남습니다.</p>\n          </div>\n        </div>\n        <ul v-if=\"recentLogs.length\" class=\"mail-log-list\">\n          <li v-for=\"log in recentLogs\" :key=\"log.id\" class=\"mail-log-item\" :class=\"{ success: log.success }\">\n            <div>\n              <strong>{{ log.questionTitle || log.mailType }}</strong>\n              <p>{{ log.message }}</p>\n            </div>\n            <span>{{ formatDate(log.createdAt) }}</span>\n          </li>\n        </ul>\n        <div v-else class=\"empty-state\">\n          <h2>발송 로그가 없습니다</h2>\n          <p>테스트 메일을 보내거나 Batch가 실행되면 여기에 결과가 표시됩니다.</p>\n        </div>\n      </section>\n    </main>\n    <div v-if=\"openedContent\" class=\"modal-backdrop\" @click.self=\"openedContent = null\">\n      <article class=\"modal-panel markdown-modal\">\n        <div class=\"section-head\">\n          <div>\n            <span class=\"badge\">{{ openedContent.track }}</span>\n            <h2>{{ openedContent.title }}</h2>\n          </div>\n          <button class=\"secondary small\" type=\"button\" @click=\"openedContent = null\">닫기</button>\n        </div>\n        <pre class=\"markdown-preview\">{{ openedContent.content }}</pre>\n      </article>\n    </div>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport {\n  getMailContent,\n  getMailContents,\n  getMailDashboard,\n  getRandomMailQuestion,\n  sendTestMail,\n  submitMailAnswer,\n  updateMailSubscription,\n} from '../api/codemong'\n\nexport default {\n  name: 'MailServicePage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      loading: false,\n      sending: false,\n      hasError: false,\n      message: '',\n      subscription: { enabled: false, email: '' },\n      enabledDraft: false,\n      emailDraft: '',\n      previewQuestion: null,\n      previewContent: null,\n      recentLogs: [],\n      question: null,\n      answerContent: '',\n      codeContent: '',\n      answerResult: null,\n      evaluating: false,\n      contents: [],\n      openedContent: null,\n    }\n  },\n  created() {\n    this.loadDashboard()\n    this.loadQuestion()\n    this.loadContents()\n  },\n  methods: {\n    async loadDashboard() {\n      this.loading = true\n      this.message = ''\n      this.hasError = false\n      try {\n        const dashboard = await getMailDashboard()\n        this.subscription = dashboard.subscription || { enabled: false, email: '' }\n        this.enabledDraft = this.subscription.enabled\n        this.emailDraft = this.subscription.email || ''\n        this.previewQuestion = dashboard.previewQuestion\n        this.previewContent = dashboard.previewContent\n        this.recentLogs = dashboard.recentLogs || []\n      } catch (error) {\n        this.hasError = true\n        this.message = error.message\n      } finally {\n        this.loading = false\n      }\n    },\n    async loadQuestion() {\n      this.answerResult = null\n      this.question = await getRandomMailQuestion()\n    },\n    async submitAnswer() {\n      if (!this.question) return\n      this.evaluating = true\n      try {\n        this.answerResult = await submitMailAnswer(this.question.id, {\n          content: this.answerContent,\n          codeContent: this.codeContent,\n        })\n      } catch (error) {\n        this.answerResult = { score: 0, feedback: error.message }\n      } finally {\n        this.evaluating = false\n      }\n    },\n    async loadContents() {\n      this.contents = await getMailContents()\n    },\n    async openContent(content) {\n      this.openedContent = await getMailContent(content.id)\n    },\n    async saveSubscription() {\n      if (this.enabledDraft && !this.subscription.email && !this.emailDraft) {\n        this.hasError = true\n        this.message = '메일을 받을 이메일을 입력하세요.'\n        return\n      }\n      try {\n        this.subscription = await updateMailSubscription(this.enabledDraft, this.emailDraft)\n        this.enabledDraft = this.subscription.enabled\n        this.emailDraft = this.subscription.email || ''\n        this.hasError = false\n        this.message = this.subscription.enabled ? '메일 구독이 켜졌습니다.' : '메일 구독이 꺼졌습니다.'\n      } catch (error) {\n        this.hasError = true\n        this.message = error.message\n        this.enabledDraft = this.subscription.enabled\n      }\n    },\n    async sendTest() {\n      this.sending = true\n      this.message = ''\n      try {\n        const log = await sendTestMail()\n        this.hasError = !log.success\n        this.message = log.message\n        await this.loadDashboard()\n      } catch (error) {\n        this.hasError = true\n        this.message = error.message\n      } finally {\n        this.sending = false\n      }\n    },\n    formatDate(value) {\n      if (!value) return ''\n      return new Date(value).toLocaleString()\n    },\n  },\n  computed: {\n    requiresEmailInput() {\n      return this.enabledDraft && !this.subscription.email\n    },\n  },\n}\n</script>\n"],"mappings":"AAgJA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SACAC,cAAA,EACAC,eAAA,EACAC,gBAAA,EACAC,qBAAA,EACAC,YAAA,EACAC,gBAAA,EACAC,sBAAA,QACA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAV,SAAA;IAAAC;EAAA;EACAU,KAAA;IACA;MACAC,OAAA;MACAC,OAAA;MACAC,QAAA;MACAC,OAAA;MACAC,YAAA;QAAAC,OAAA;QAAAC,KAAA;MAAA;MACAC,YAAA;MACAC,UAAA;MACAC,eAAA;MACAC,cAAA;MACAC,UAAA;MACAC,QAAA;MACAC,aAAA;MACAC,WAAA;MACAC,YAAA;MACAC,UAAA;MACAC,QAAA;MACAC,aAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,aAAA;IACA,KAAAC,YAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACA,MAAAH,cAAA;MACA,KAAApB,OAAA;MACA,KAAAG,OAAA;MACA,KAAAD,QAAA;MACA;QACA,MAAAsB,SAAA,SAAAhC,gBAAA;QACA,KAAAY,YAAA,GAAAoB,SAAA,CAAApB,YAAA;UAAAC,OAAA;UAAAC,KAAA;QAAA;QACA,KAAAC,YAAA,QAAAH,YAAA,CAAAC,OAAA;QACA,KAAAG,UAAA,QAAAJ,YAAA,CAAAE,KAAA;QACA,KAAAG,eAAA,GAAAe,SAAA,CAAAf,eAAA;QACA,KAAAC,cAAA,GAAAc,SAAA,CAAAd,cAAA;QACA,KAAAC,UAAA,GAAAa,SAAA,CAAAb,UAAA;MACA,SAAAc,KAAA;QACA,KAAAvB,QAAA;QACA,KAAAC,OAAA,GAAAsB,KAAA,CAAAtB,OAAA;MACA;QACA,KAAAH,OAAA;MACA;IACA;IACA,MAAAqB,aAAA;MACA,KAAAN,YAAA;MACA,KAAAH,QAAA,SAAAnB,qBAAA;IACA;IACA,MAAAiC,aAAA;MACA,UAAAd,QAAA;MACA,KAAAI,UAAA;MACA;QACA,KAAAD,YAAA,SAAApB,gBAAA,MAAAiB,QAAA,CAAAe,EAAA;UACAC,OAAA,OAAAf,aAAA;UACAC,WAAA,OAAAA;QACA;MACA,SAAAW,KAAA;QACA,KAAAV,YAAA;UAAAc,KAAA;UAAAC,QAAA,EAAAL,KAAA,CAAAtB;QAAA;MACA;QACA,KAAAa,UAAA;MACA;IACA;IACA,MAAAM,aAAA;MACA,KAAAL,QAAA,SAAA1B,eAAA;IACA;IACA,MAAAwC,YAAAH,OAAA;MACA,KAAAV,aAAA,SAAA5B,cAAA,CAAAsC,OAAA,CAAAD,EAAA;IACA;IACA,MAAAK,iBAAA;MACA,SAAAzB,YAAA,UAAAH,YAAA,CAAAE,KAAA,UAAAE,UAAA;QACA,KAAAN,QAAA;QACA,KAAAC,OAAA;QACA;MACA;MACA;QACA,KAAAC,YAAA,SAAAR,sBAAA,MAAAW,YAAA,OAA