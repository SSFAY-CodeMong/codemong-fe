{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getProjects, saveSelectedProject } from '../api/codemong';\nexport default {\n  name: 'ProjectsPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      projects: [],\n      selected: null,\n      error: '',\n      heroImage: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1400&q=80',\n      projectImages: ['https://images.unsplash.com/photo-1515879218367-8466d910aaa4?auto=format&fit=crop&w=900&q=80', 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=900&q=80', 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=900&q=80']\n    };\n  },\n  async created() {\n    try {\n      this.projects = await getProjects();\n      this.selected = this.projects[0] || null;\n      if (!this.projects.length) this.error = '등록된 프로젝트가 없습니다. 백엔드 seed 데이터를 확인하세요.';\n    } catch (error) {\n      this.error = error.message;\n    }\n  },\n  methods: {\n    select(project) {\n      this.selected = project;\n    },\n    goSetup() {\n      saveSelectedProject(this.selected);\n      this.$router.push('/project-setup');\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getProjects","saveSelectedProject","name","components","data","projects","selected","error","heroImage","projectImages","created","length","message","methods","select","project","goSetup","$router","push"],"sources":["src/views/projects-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"projects\" />\n    <main class=\"projects-page\">\n      <section class=\"projects-hero\">\n        <img :src=\"heroImage\" alt=\"Developers reviewing code on monitors\" />\n        <div>\n          <span class=\"badge\">Project Catalog</span>\n          <h1>실전 프로젝트로 스텝을 열어가세요</h1>\n          <p>Codemong은 starter 코드, GitHub 브랜치, Actions 검사를 하나의 학습 흐름으로 묶습니다.</p>\n        </div>\n      </section>\n\n      <section class=\"page project-catalog\">\n        <div class=\"project-list\">\n          <p v-if=\"error\" class=\"status fail\">{{ error }}</p>\n          <article\n            v-for=\"(project, index) in projects\"\n            :key=\"project.id\"\n            class=\"project-card-rich\"\n            :class=\"{ selected: selected && selected.id === project.id }\"\n            @click=\"select(project)\"\n          >\n            <img :src=\"projectImages[index % projectImages.length]\" :alt=\"`${project.name} project preview`\" />\n            <div>\n              <span class=\"badge\">{{ project.category }}</span>\n              <h2>{{ project.title || project.name }}</h2>\n              <p>{{ project.description }}</p>\n              <div class=\"project-meta\">\n                <span>{{ project.steps }} steps</span>\n                <span>{{ project.difficulty }}</span>\n                <span>{{ project.type }}</span>\n              </div>\n            </div>\n          </article>\n        </div>\n\n        <aside class=\"project-detail-rich\" v-if=\"selected\">\n          <span class=\"badge\">{{ selected.category }}</span>\n          <h2>{{ selected.title || selected.name }}</h2>\n          <p>{{ selected.description }}</p>\n          <div class=\"detail-block\">\n            <h3>학습 목표</h3>\n            <ul class=\"check-list\">\n              <li v-for=\"goal in selected.goals\" :key=\"goal\">{{ goal }}</li>\n            </ul>\n          </div>\n          <div class=\"detail-block\">\n            <h3>기술 스택</h3>\n            <div class=\"tag-row\">\n              <span v-for=\"stack in selected.stacks\" :key=\"stack\">{{ stack }}</span>\n            </div>\n          </div>\n          <button class=\"primary\" type=\"button\" @click=\"goSetup\">시작 스텝 선택</button>\n        </aside>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getProjects, saveSelectedProject } from '../api/codemong'\n\nexport default {\n  name: 'ProjectsPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      projects: [],\n      selected: null,\n      error: '',\n      heroImage: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1400&q=80',\n      projectImages: [\n        'https://images.unsplash.com/photo-1515879218367-8466d910aaa4?auto=format&fit=crop&w=900&q=80',\n        'https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=900&q=80',\n        'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=900&q=80',\n      ],\n    }\n  },\n  async created() {\n    try {\n      this.projects = await getProjects()\n      this.selected = this.projects[0] || null\n      if (!this.projects.length) this.error = '등록된 프로젝트가 없습니다. 백엔드 seed 데이터를 확인하세요.'\n    } catch (error) {\n      this.error = error.message\n    }\n  },\n  methods: {\n    select(project) {\n      this.selected = project\n    },\n    goSetup() {\n      saveSelectedProject(this.selected)\n      this.$router.push('/project-setup')\n    },\n  },\n}\n</script>\n"],"mappings":";AA8DA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,WAAA,EAAAC,mBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAL,SAAA;IAAAC;EAAA;EACAK,KAAA;IACA;MACAC,QAAA;MACAC,QAAA;MACAC,KAAA;MACAC,SAAA;MACAC,aAAA,GACA,gGACA,6FACA;IAEA;EACA;EACA,MAAAC,QAAA;IACA;MACA,KAAAL,QAAA,SAAAL,WAAA;MACA,KAAAM,QAAA,QAAAD,QAAA;MACA,UAAAA,QAAA,CAAAM,MAAA,OAAAJ,KAAA;IACA,SAAAA,KAAA;MACA,KAAAA,KAAA,GAAAA,KAAA,CAAAK,OAAA;IACA;EACA;EACAC,OAAA;IACAC,OAAAC,OAAA;MACA,KAAAT,QAAA,GAAAS,OAAA;IACA;IACAC,QAAA;MACAf,mBAAA,MAAAK,QAAA;MACA,KAAAW,OAAA,CAAAC,IAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}