{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getRepositoryReports, getSavedRepository } from '../api/codemong';\nexport default {\n  name: 'ReportsPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      reports: [],\n      loading: false,\n      message: ''\n    };\n  },\n  created() {\n    this.loadReports();\n  },\n  methods: {\n    async loadReports() {\n      const repository = getSavedRepository();\n      if (!repository) {\n        this.message = '선택된 저장소가 없습니다.';\n        return;\n      }\n      this.loading = true;\n      this.message = '';\n      try {\n        this.reports = await getRepositoryReports(repository.repositoryId);\n      } catch (error) {\n        this.message = error.message;\n      } finally {\n        this.loading = false;\n      }\n    },\n    formatDate(value) {\n      if (!value) return '';\n      return new Date(value).toLocaleString();\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getRepositoryReports","getSavedRepository","name","components","data","reports","loading","message","created","loadReports","methods","repository","repositoryId","error","formatDate","value","Date","toLocaleString"],"sources":["src/views/reports-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"progress\" />\n    <main class=\"page reports-page\">\n      <section class=\"section-head\">\n        <div>\n          <span class=\"badge\">Reports</span>\n          <h1>프로젝트 리포트</h1>\n          <p>리포트 생성 로직이 연결되면 이곳에 항목별 리포트가 표시됩니다.</p>\n        </div>\n        <button class=\"secondary\" type=\"button\" @click=\"loadReports\" :disabled=\"loading\">\n          {{ loading ? '불러오는 중' : '새로고침' }}\n        </button>\n      </section>\n\n      <section v-if=\"message\" class=\"panel\">\n        <p class=\"status fail\">{{ message }}</p>\n      </section>\n\n      <section v-else-if=\"!reports.length\" class=\"empty-state report-empty\">\n        <h2>아직 생성된 리포트가 없습니다</h2>\n        <p>현재는 조회 API 연결 틀만 준비되어 있습니다. 리포트 생성 로직이 추가되면 자동으로 목록에 표시됩니다.</p>\n      </section>\n\n      <section v-else class=\"report-grid\">\n        <article v-for=\"report in reports\" :key=\"report.id\" class=\"report-card\">\n          <div class=\"progress-card__top\">\n            <strong>Report #{{ report.id }}</strong>\n            <span class=\"badge\">{{ report.score }}점</span>\n          </div>\n          <p>{{ formatDate(report.createdAt) }}</p>\n          <div class=\"answer-box report-content\">{{ report.content }}</div>\n        </article>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getRepositoryReports, getSavedRepository } from '../api/codemong'\n\nexport default {\n  name: 'ReportsPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      reports: [],\n      loading: false,\n      message: '',\n    }\n  },\n  created() {\n    this.loadReports()\n  },\n  methods: {\n    async loadReports() {\n      const repository = getSavedRepository()\n      if (!repository) {\n        this.message = '선택된 저장소가 없습니다.'\n        return\n      }\n      this.loading = true\n      this.message = ''\n      try {\n        this.reports = await getRepositoryReports(repository.repositoryId)\n      } catch (error) {\n        this.message = error.message\n      } finally {\n        this.loading = false\n      }\n    },\n    formatDate(value) {\n      if (!value) return ''\n      return new Date(value).toLocaleString()\n    },\n  },\n}\n</script>\n"],"mappings":"AAwCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,oBAAA,EAAAC,kBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAL,SAAA;IAAAC;EAAA;EACAK,KAAA;IACA;MACAC,OAAA;MACAC,OAAA;MACAC,OAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,WAAA;EACA;EACAC,OAAA;IACA,MAAAD,YAAA;MACA,MAAAE,UAAA,GAAAV,kBAAA;MACA,KAAAU,UAAA;QACA,KAAAJ,OAAA;QACA;MACA;MACA,KAAAD,OAAA;MACA,KAAAC,OAAA;MACA;QACA,KAAAF,OAAA,SAAAL,oBAAA,CAAAW,UAAA,CAAAC,YAAA;MACA,SAAAC,KAAA;QACA,KAAAN,OAAA,GAAAM,KAAA,CAAAN,OAAA;MACA;QACA,KAAAD,OAAA;MACA;IACA;IACAQ,WAAAC,KAAA;MACA,KAAAA,KAAA;MACA,WAAAC,IAAA,CAAAD,KAAA,EAAAE,cAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}