{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { loginWithGithub, reissueToken } from '../api/codemong';\nexport default {\n  name: 'LoginPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      message: ''\n    };\n  },\n  async created() {\n    // 소셜 로그인 완료 후 리다이렉트되거나 로그인 페이지 진입 시 자동으로 세션 연동 시도\n    try {\n      await reissueToken();\n      this.$router.push('/projects');\n    } catch (error) {\n      // 비로그인 상태인 경우 에러 무시하고 로그인 버튼 활성화 유지\n    }\n  },\n  methods: {\n    loginWithGithub,\n    async refresh() {\n      try {\n        await reissueToken();\n        this.message = '로그인 상태가 확인되었습니다.';\n        this.$router.push('/projects');\n      } catch (error) {\n        this.message = '로그인이 필요합니다.';\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","loginWithGithub","reissueToken","name","components","data","message","created","$router","push","error","methods","refresh"],"sources":["src/views/login-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader />\n    <main class=\"page\">\n      <section class=\"panel\">\n        <h1>GitHub 로그인</h1>\n        <p>GitHub OAuth로 로그인하면 Codemong이 학습 저장소를 만들고 검사 워크플로를 실행할 수 있습니다.</p>\n        <div class=\"toolbar\">\n          <button class=\"primary\" type=\"button\" @click=\"loginWithGithub\">GitHub로 시작하기</button>\n          <button class=\"secondary\" type=\"button\" @click=\"refresh\">로그인 상태 확인</button>\n        </div>\n        <p class=\"muted\">{{ message }}</p>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { loginWithGithub, reissueToken } from '../api/codemong'\n\nexport default {\n  name: 'LoginPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return { message: '' }\n  },\n  async created() {\n    // 소셜 로그인 완료 후 리다이렉트되거나 로그인 페이지 진입 시 자동으로 세션 연동 시도\n    try {\n      await reissueToken()\n      this.$router.push('/projects')\n    } catch (error) {\n      // 비로그인 상태인 경우 에러 무시하고 로그인 버튼 활성화 유지\n    }\n  },\n  methods: {\n    loginWithGithub,\n    async refresh() {\n      try {\n        await reissueToken()\n        this.message = '로그인 상태가 확인되었습니다.'\n        this.$router.push('/projects')\n      } catch (error) {\n        this.message = '로그인이 필요합니다.'\n      }\n    },\n  },\n}\n</script>\n"],"mappings":";AAmBA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,eAAA,EAAAC,YAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAL,SAAA;IAAAC;EAAA;EACAK,KAAA;IACA;MAAAC,OAAA;IAAA;EACA;EACA,MAAAC,QAAA;IACA;IACA;MACA,MAAAL,YAAA;MACA,KAAAM,OAAA,CAAAC,IAAA;IACA,SAAAC,KAAA;MACA;IAAA;EAEA;EACAC,OAAA;IACAV,eAAA;IACA,MAAAW,QAAA;MACA;QACA,MAAAV,YAAA;QACA,KAAAI,OAAA;QACA,KAAAE,OAAA,CAAAC,IAAA;MACA,SAAAC,KAAA;QACA,KAAAJ,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}