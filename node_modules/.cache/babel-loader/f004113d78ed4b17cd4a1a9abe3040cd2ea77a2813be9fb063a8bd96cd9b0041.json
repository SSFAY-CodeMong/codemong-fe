{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getProjectSteps, getSelectedProject, startProject } from '../api/codemong';\nexport default {\n  name: 'ProjectSetupPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      project: null,\n      steps: [],\n      startStep: 1,\n      track: 'BE',\n      loading: false,\n      message: ''\n    };\n  },\n  async created() {\n    this.project = getSelectedProject();\n    if (!this.project) {\n      this.$router.replace('/projects');\n      return;\n    }\n    this.track = this.project.type || 'BE';\n    this.steps = await getProjectSteps(this.project.id);\n  },\n  methods: {\n    async start() {\n      this.loading = true;\n      this.message = '';\n      try {\n        await startProject(this.project.id, {\n          startStep: this.startStep,\n          track: this.track\n        });\n        this.$router.push('/project-initializing');\n      } catch (error) {\n        this.message = error.message;\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getProjectSteps","getSelectedProject","startProject","name","components","data","project","steps","startStep","track","loading","message","created","$router","replace","type","id","methods","start","push","error"],"sources":["src/views/project-setup-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"projects\" />\n    <main class=\"page layout\">\n      <section class=\"panel\">\n        <h1>프로젝트 설정</h1>\n        <p v-if=\"project\">{{ project.name }}의 시작 스텝과 트랙을 선택하세요.</p>\n        <form class=\"form\" @submit.prevent=\"start\">\n          <label>\n            시작 스텝\n            <select v-model.number=\"startStep\">\n              <option v-for=\"step in steps\" :key=\"step.step\" :value=\"step.step\">\n                {{ step.stepId }} · {{ step.title }}\n              </option>\n            </select>\n          </label>\n          <label>\n            트랙\n            <select v-model=\"track\">\n              <option value=\"BE\">Backend</option>\n              <option value=\"FE\">Frontend</option>\n            </select>\n          </label>\n          <button class=\"primary\" type=\"submit\" :disabled=\"loading\">{{ loading ? '생성 중' : '프로젝트 시작' }}</button>\n        </form>\n        <p class=\"muted\">{{ message }}</p>\n      </section>\n      <aside class=\"panel\">\n        <h2>스텝 목록</h2>\n        <ul class=\"list\">\n          <li v-for=\"step in steps\" :key=\"step.stepId\">{{ step.stepId }} · {{ step.description }}</li>\n        </ul>\n      </aside>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getProjectSteps, getSelectedProject, startProject } from '../api/codemong'\n\nexport default {\n  name: 'ProjectSetupPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      project: null,\n      steps: [],\n      startStep: 1,\n      track: 'BE',\n      loading: false,\n      message: '',\n    }\n  },\n  async created() {\n    this.project = getSelectedProject()\n    if (!this.project) {\n      this.$router.replace('/projects')\n      return\n    }\n    this.track = this.project.type || 'BE'\n    this.steps = await getProjectSteps(this.project.id)\n  },\n  methods: {\n    async start() {\n      this.loading = true\n      this.message = ''\n      try {\n        await startProject(this.project.id, { startStep: this.startStep, track: this.track })\n        this.$router.push('/project-initializing')\n      } catch (error) {\n        this.message = error.message\n      } finally {\n        this.loading = false\n      }\n    },\n  },\n}\n</script>\n"],"mappings":";AAuCA,OAAAA,SAAA;AACA,OAAAC