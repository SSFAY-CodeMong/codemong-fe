{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getSavedRepository } from '../api/codemong';\nexport default {\n  name: 'ProjectInitializingPage',\n  components: {\n    AppFooter: AppFooter,\n    AppHeader: AppHeader\n  },\n  data: function data() {\n    return {\n      repository: getSavedRepository()\n    };\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getSavedRepository","name","components","data","repository"],"sources":["src/views/project-initializing-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mission\" />\n    <main class=\"page\">\n      <section class=\"panel\">\n        <h1>저장소 준비 완료</h1>\n        <p>GitHub 저장소와 첫 번째 작업 브랜치가 생성되었습니다.</p>\n        <div class=\"toolbar\">\n          <button class=\"primary\" type=\"button\" @click=\"$router.push('/mission-workspace')\">미션으로 이동</button>\n          <a v-if=\"repository\" class=\"secondary\" :href=\"repository.htmlUrl\" target=\"_blank\" rel=\"noreferrer\">GitHub 열기</a>\n        </div>\n      </section>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getSavedRepository } from '../api/codemong'\n\nexport default {\n  name: 'ProjectInitializingPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return { repository: getSavedRepository() }\n  },\n}\n</script>\n"],"mappings":"AAkBA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,kBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAJ,SAAA,EAAAA,SAAA;IAAAC,SAAA,EAAAA;EAAA;EACAI,IAAA,WAAAA,KAAA;IACA;MAAAC,UAAA,EAAAJ,kBAAA;IAAA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}