      type: String,\n      default: '',\n    },\n  },\n  data() {\n    return {\n      navigation: getNavigation(),\n      user: null,\n    }\n  },\n  async created() {\n    try {\n      this.user = await getMe()\n    } catch (error) {\n      this.user = null\n    }\n  },\n  methods: {\n    async logout() {\n      try {\n        await logout()\n      } catch (error) {\n        clearSession()\n      }\n      this.user = null\n      if (this.$route.path !== '/') {\n        this.$router.push('/')\n      }\n    },\n  },\n}\n</script>\n"],"mappings":";AAuBA,SAAAA,YAAA,EAAAC,KAAA,EAAAC,aAAA,EAAAC,MAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACAC,UAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;EACA;EACAC,KAAA;IACA;MACAC,UAAA,EAAAT,aAAA;MACAU,IAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA;MACA,KAAAD,IAAA,SAAAX,KAAA;IACA,SAAAa,KAAA;MACA,KAAAF,IAAA;IACA;EACA;EACAG,OAAA;IACA,MAAAZ,OAAA;MACA;QACA,MAAAA,MAAA;MACA,SAAAW,KAAA;QACAd,YAAA;MACA;MACA,KAAAY,IAAA;MACA,SAAAI,MAAA,CAAAC,IAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}