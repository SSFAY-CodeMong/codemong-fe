{"ast":null,"code":"import AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { askCodeQuestion, getSavedRepository } from '../api/codemong';\nexport default {\n  name: 'FrontendAiFeedbackPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      question: '',\n      answer: '',\n      loading: false,\n      repository: getSavedRepository()\n    };\n  },\n  methods: {\n    async ask() {\n      this.loading = true;\n      try {\n        const result = await askCodeQuestion(this.repository.repositoryId, this.question);\n        this.answer = result.answer || result.response || JSON.stringify(result);\n      } catch (error) {\n        this.answer = error.message;\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","askCodeQuestion","getSavedRepository","name","components","data","question","answer","loading","repository","methods","ask","result","repositoryId","response","JSON","stringify","error","message"],"sources":["src/views/frontend-ai-feedback-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"mission\" />\n    <main class=\"page layout\">\n      <section class=\"panel\">\n        <h1>코드 질문</h1>\n        <p>LLM 응답 API가 연결되어 있으면 현재 저장소 코드 맥락으로 질문할 수 있습니다.</p>\n        <form class=\"form\" @submit.prevent=\"ask\">\n          <label>\n            질문\n            <textarea v-model=\"question\" rows=\"5\" placeholder=\"어떤 부분을 고치면 좋을까요?\"></textarea>\n          </label>\n          <button class=\"primary\" type=\"submit\" :disabled=\"loading\">질문하기</button>\n        </form>\n      </section>\n      <aside class=\"panel\">\n        <h2>응답</h2>\n        <p>{{ answer || '아직 응답이 없습니다.' }}</p>\n      </aside>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { askCodeQuestion, getSavedRepository } from '../api/codemong'\n\nexport default {\n  name: 'FrontendAiFeedbackPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      question: '',\n      answer: '',\n      loading: false,\n      repository: getSavedRepository(),\n    }\n  },\n  methods: {\n    async ask() {\n      this.loading = true\n      try {\n        const result = await askCodeQuestion(this.repository.repositoryId, this.question)\n        this.answer = result.answer || result.response || JSON.stringify(result)\n      } catch (error) {\n        this.answer = error.message\n      } finally {\n        this.loading = false\n      }\n    },\n  },\n}\n</script>\n"],"mappings":"AAyBA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,eAAA,EAAAC,kBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAL,SAAA;IAAAC;EAAA;EACAK,KAAA;IACA;MACAC,QAAA;MACAC,MAAA;MACAC,OAAA;MACAC,UAAA,EAAAP,kBAAA;IACA;EACA;EACAQ,OAAA;IACA,MAAAC,IAAA;MACA,KAAAH,OAAA;MACA;QACA,MAAAI,MAAA,SAAAX,eAAA,MAAAQ,UAAA,CAAAI,YAAA,OAAAP,QAAA;QACA,KAAAC,MAAA,GAAAK,MAAA,CAAAL,MAAA,IAAAK,MAAA,CAAAE,QAAA,IAAAC,IAAA,CAAAC,SAAA,CAAAJ,MAAA;MACA,SAAAK,KAAA;QACA,KAAAV,MAAA,GAAAU,KAAA,CAAAC,OAAA;MACA;QACA,KAAAV,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}