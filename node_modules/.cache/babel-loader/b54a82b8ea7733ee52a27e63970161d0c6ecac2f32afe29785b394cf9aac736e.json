{"ast":null,"code":"import \"core-js/modules/es.array.includes.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport AppFooter from '../components/AppFooter.vue';\nimport AppHeader from '../components/AppHeader.vue';\nimport { getProjectSteps, getSelectedProject, startProject } from '../api/codemong';\nexport default {\n  name: 'ProjectSetupPage',\n  components: {\n    AppFooter,\n    AppHeader\n  },\n  data() {\n    return {\n      project: null,\n      steps: [],\n      startStep: 1,\n      loading: false,\n      message: '',\n      needsLogin: false\n    };\n  },\n  computed: {\n    track() {\n      return this.project && this.project.type || 'BE';\n    },\n    trackLabel() {\n      return this.track === 'FE' ? 'Frontend' : 'Backend';\n    }\n  },\n  async created() {\n    this.project = getSelectedProject();\n    if (!this.project) {\n      this.$router.replace('/projects');\n      return;\n    }\n    this.steps = await getProjectSteps(this.project.id);\n  },\n  methods: {\n    async start() {\n      this.loading = true;\n      this.message = '';\n      this.needsLogin = false;\n      try {\n        await startProject(this.project.id, {\n          startStep: this.startStep,\n          track: this.track\n        });\n        this.$router.push('/project-initializing');\n      } catch (error) {\n        this.message = error.message;\n        this.needsLogin = error.message.includes('로그인');\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppFooter","AppHeader","getProjectSteps","getSelectedProject","startProject","name","components","data","project","steps","startStep","loading","message","needsLogin","computed","track","type","trackLabel","created","$router","replace","id","methods","start","push","error","includes"],"sources":["src/views/project-setup-page.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppHeader active-page=\"projects\" />\n    <main class=\"page layout\">\n      <section class=\"panel\">\n        <h1>프로젝트 설정</h1>\n        <p v-if=\"project\">{{ project.name }}의 시작 스텝을 선택하세요.</p>\n        <form class=\"form\" @submit.prevent=\"start\">\n          <label>\n            시작 스텝\n            <select v-model.number=\"startStep\">\n              <option v-for=\"step in steps\" :key=\"step.step\" :value=\"step.step\">\n                {{ step.stepId }} · {{ step.title }}\n              </option>\n            </select>\n          </label>\n          <div>\n            <strong>트랙</strong>\n            <p class=\"muted\">프로젝트 타입 기준으로 고정됩니다: {{ trackLabel }}</p>\n          </div>\n          <button class=\"primary\" type=\"submit\" :disabled=\"loading\">\n            {{ loading ? '생성 중' : '프로젝트 시작' }}\n          </button>\n        </form>\n        <p class=\"muted\">{{ message }}</p>\n        <button v-if=\"needsLogin\" class=\"secondary\" type=\"button\" @click=\"$router.push('/login')\">\n          GitHub 로그인으로 이동\n        </button>\n      </section>\n      <aside class=\"panel\">\n        <h2>스텝 목록</h2>\n        <ul class=\"list\">\n          <li v-for=\"step in steps\" :key=\"step.stepId\">{{ step.stepId }} · {{ step.description }}</li>\n        </ul>\n      </aside>\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script>\nimport AppFooter from '../components/AppFooter.vue'\nimport AppHeader from '../components/AppHeader.vue'\nimport { getProjectSteps, getSelectedProject, startProject } from '../api/codemong'\n\nexport default {\n  name: 'ProjectSetupPage',\n  components: { AppFooter, AppHeader },\n  data() {\n    return {\n      project: null,\n      steps: [],\n      startStep: 1,\n      loading: false,\n      message: '',\n      needsLogin: false,\n    }\n  },\n  computed: {\n    track() {\n      return (this.project && this.project.type) || 'BE'\n    },\n    trackLabel() {\n      return this.track === 'FE' ? 'Frontend' : 'Backend'\n    },\n  },\n  async created() {\n    this.project = getSelectedProject()\n    if (!this.project) {\n      this.$router.replace('/projects')\n      return\n    }\n    this.steps = await getProjectSteps(this.project.id)\n  },\n  methods: {\n    async start() {\n      this.loading = true\n      this.message = ''\n      this.needsLogin = false\n      try {\n        await startProject(this.project.id, { startStep: this.startStep, track: this.track })\n        this.$router.push('/project-initializing')\n      } catch (error) {\n        this.message = error.message\n        this.needsLogin = error.message.includes('로그인')\n      } finally {\n        this.loading = false\n      }\n    },\n  },\n}\n</script>\n"],"mappings":";;AAyCA,OAAAA,SAAA;AACA,OAAAC,SAAA;AACA,SAAAC,eAAA,EAAAC,kBAAA,EAAAC,YAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAN,SAAA;IAAAC;EAAA;EACAM,KAAA;IACA;MACAC,OAAA;MACAC,KAAA;MACAC,SAAA;MACAC,OAAA;MACAC,OAAA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACAC,MAAA;MACA,YAAAP,OAAA,SAAAA,OAAA,CAAAQ,IAAA;IACA;IACAC,WAAA;MACA,YAAAF,KAAA;IACA;EACA;EACA,MAAAG,QAAA;IACA,KAAAV,OAAA,GAAAL,kBAAA;IACA,UAAAK,OAAA;MACA,KAAAW,OAAA,CAAAC,OAAA;MACA;IACA;IACA,KAAAX,KAAA,SAAAP,eAAA,MAAAM,OAAA,CAAAa,EAAA;EACA;EACAC,OAAA;IACA,MAAAC,MAAA;MACA,KAAAZ,OAAA;MACA,KAAAC,OAAA;MACA,KAAAC,UAAA;MACA;QACA,MAAAT,YAAA,MAAAI,OAAA,CAAAa,EAAA;UAAAX,SAAA,OAAAA,SAAA;UAAAK,KAAA,OAAAA;QAAA;QACA,KAAAI,OAAA,CAAAK,IAAA;MACA,SAAAC,KAAA;QACA,KAAAb,OAAA,GAAAa,KAAA,CAAAb,OAAA;QACA,KAAAC,UAAA,GAAAY,KAAA,CAAAb,OAAA,CAAAc,QAAA;MACA;QACA,KAAAf,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}